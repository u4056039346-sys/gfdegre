			Knob.Text = ""
			Knob.ZIndex = 6
			Knob.Parent = TrackBG
			MakeCorner(Knob, 6)

			local draggingSlider = false
			Knob.MouseButton1Down:Connect(function() draggingSlider = true end)
			UserInputService.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 then draggingSlider = false end
			end)
			UserInputService.InputChanged:Connect(function(i)
				if draggingSlider and i.UserInputType == Enum.UserInputType.MouseMovement then
					local pct = math.clamp((i.Position.X - TrackBG.AbsolutePosition.X) / TrackBG.AbsoluteSize.X, 0, 1)
					value = math.floor(min + (max - min) * pct + 0.5)
					Val.Text = tostring(value)
					Fill.Size = UDim2.new(pct, 0, 1, 0)
					Knob.Position = UDim2.new(pct, -6, 0.5, -6)
					if callback then callback(value) end
				end
			end)

			local ctrl = {}
			function ctrl:Set(v)
				value = math.clamp(v, min, max)
				local pct = (value - min) / (max - min)
				Val.Text = tostring(value)
				Fill.Size = UDim2.new(pct, 0, 1, 0)
				Knob.Position = UDim2.new(pct, -6, 0.5, -6)
				if callback then callback(value) end
			end
			function ctrl:Get() return value end
			return ctrl
		end

		function Tab:AddTextbox(label, placeholder, callback, subTab)
			local frame = getFrame(subTab)
			if not frame then return end

			local Row = Instance.new("Frame")
			Row.BackgroundColor3 = C.ITEM
			Row.BorderSizePixel = 0
			Row.Size = UDim2.new(1, 0, 0, 56)
			Row.ZIndex = 3
			Row.Parent = frame
			MakeCorner(Row, 4)

			local L = Instance.new("TextLabel")
			L.BackgroundTransparency = 1
			L.Size = UDim2.new(1, -16, 0, 20)
			L.Position = UDim2.new(0, 16, 0, 5)
			L.Font = Enum.Font.GothamBold
			L.Text = label
			L.TextColor3 = C.TEXT1
			L.TextSize = 12
			L.TextXAlignment = Enum.TextXAlignment.Left
			L.ZIndex = 4
			L.Parent = Row

			local InputF = Instance.new("Frame")
			InputF.BackgroundColor3 = C.INPUT_BG
			InputF.BorderSizePixel = 0
			InputF.Size = UDim2.new(1, -32, 0, 22)
			InputF.Position = UDim2.new(0, 16, 0, 28)
			InputF.ZIndex = 4
			InputF.Parent = Row
			MakeCorner(InputF, 4)

			local Box = Instance.new("TextBox")
			Box.BackgroundTransparency = 1
			Box.Size = UDim2.new(1, -12, 1, 0)
			Box.Position = UDim2.new(0, 6, 0, 0)
			Box.Font = Enum.Font.Gotham
			Box.PlaceholderText = placeholder or ""
			Box.PlaceholderColor3 = C.TEXT3
			Box.Text = ""
			Box.TextColor3 = C.TEXT1
			Box.TextSize = 11
			Box.TextXAlignment = Enum.TextXAlignment.Left
			Box.ClearTextOnFocus = false
			Box.ZIndex = 5
			Box.Parent = InputF

			Box.FocusLost:Connect(function(enter)
				if callback then callback(Box.Text, enter) end
			end)

			local ctrl = {}
			function ctrl:Set(v) Box.Text = v end
			function ctrl:Get() return Box.Text end
			return ctrl
		end

		function Tab:AddDropdown(label, options, default, callback, subTab)
			if type(default) == "function" then
				subTab = callback; callback = default; default = options[1]
			end
			local frame = getFrame(subTab)
			if not frame then return end

			local selected = default or options[1]
			local open = false

			local Row = Instance.new("Frame")
			Row.BackgroundColor3 = C.ITEM
			Row.BorderSizePixel = 0
			Row.Size = UDim2.new(1, 0, 0, 49)
			Row.ClipsDescendants = false
			Row.ZIndex = 10
			Row.Parent = frame
			MakeCorner(Row, 4)

			local L = Instance.new("TextLabel")
			L.BackgroundTransparency = 1
			L.Size = UDim2.new(1, -16, 0, 20)
			L.Position = UDim2.new(0, 16, 0, 6)
			L.Font = Enum.Font.GothamBold
			L.Text = label
			L.TextColor3 = C.TEXT1
			L.TextSize = 12
			L.TextXAlignment = Enum.TextXAlignment.Left
			L.ZIndex = 11
			L.Parent = Row

			local DropBtn = Instance.new("TextButton")
			DropBtn.BackgroundColor3 = C.INPUT_BG
			DropBtn.BorderSizePixel = 0
			DropBtn.Size = UDim2.new(1, -32, 0, 22)
			DropBtn.Position = UDim2.new(0, 16, 0, 22)
			DropBtn.Font = Enum.Font.Gotham
			DropBtn.Text = selected
			DropBtn.TextColor3 = C.TEXT2
			DropBtn.TextSize = 11
			DropBtn.TextXAlignment = Enum.TextXAlignment.Left
			DropBtn.ZIndex = 11
			DropBtn.Parent = Row
			MakeCorner(DropBtn, 4)
			MakePadding(DropBtn, 0, 0, 8, 8)

			local Arrow = Instance.new("TextLabel")
			Arrow.BackgroundTransparency = 1
			Arrow.Size = UDim2.new(0, 20, 1, 0)
			Arrow.Position = UDim2.new(1, -22, 0, 0)
			Arrow.Font = Enum.Font.GothamBold
			Arrow.Text = "▾"
			Arrow.TextColor3 = C.TEXT3
			Arrow.TextSize = 12
			Arrow.ZIndex = 12
			Arrow.Parent = DropBtn

			local DropList = Instance.new("Frame")
			DropList.BackgroundColor3 = C.DROPDOWN_BG
			DropList.BorderSizePixel = 0
			DropList.Size = UDim2.new(1, -32, 0, #options * 26 + 4)
			DropList.Position = UDim2.new(0, 16, 0, 47)
			DropList.Visible = false
			DropList.ZIndex = 20
			DropList.Parent = Row
			MakeCorner(DropList, 4)
			MakePadding(DropList, 2, 2, 4, 4)
			MakeList(DropList, 2)

			for _, opt in ipairs(options) do
				local OB = Instance.new("TextButton")
				OB.BackgroundColor3 = C.DROPDOWN_BG
				OB.BackgroundTransparency = 1
				OB.BorderSizePixel = 0
				OB.Size = UDim2.new(1, 0, 0, 22)
				OB.Font = Enum.Font.Gotham
				OB.Text = opt
				OB.TextColor3 = opt == selected and C.TEXT1 or C.TEXT2
				OB.TextSize = 11
				OB.TextXAlignment = Enum.TextXAlignment.Left
				OB.ZIndex = 21
				OB.Parent = DropList
				MakePadding(OB, 0, 0, 6, 6)
				MakeCorner(OB, 3)

				OB.MouseEnter:Connect(function() Tween(OB, {BackgroundTransparency = 0.7}, 0.1) end)
				OB.MouseLeave:Connect(function() Tween(OB, {BackgroundTransparency = 1}, 0.1) end)
				OB.MouseButton1Click:Connect(function()
					selected = opt
					DropBtn.Text = opt
					for _, o in ipairs(DropList:GetChildren()) do
						if o:IsA("TextButton") then
							o.TextColor3 = o.Text == selected and C.TEXT1 or C.TEXT2
						end
					end
					open = false
					DropList.Visible = false
					Tween(Arrow, {Rotation = 0}, 0.15)
					if callback then callback(selected) end
				end)
			end

			DropBtn.MouseButton1Click:Connect(function()
				open = not open
				DropList.Visible = open
				Tween(Arrow, {Rotation = open and 180 or 0}, 0.15)
			end)

			local ctrl = {}
			function ctrl:Set(v) selected = v DropBtn.Text = v if callback then callback(selected) end end
			function ctrl:Get() return selected end
			return ctrl
		end

		function Tab:AddLabel(text, subTab)
			local frame = getFrame(subTab)
			if not frame then return end

			local Row = Instance.new("Frame")
			Row.BackgroundColor3 = C.ITEM
			Row.BorderSizePixel = 0
			Row.Size = UDim2.new(1, 0, 0, 32)
			Row.ZIndex = 3
			Row.Parent = frame
			MakeCorner(Row, 4)

			local L = Instance.new("TextLabel")
			L.BackgroundTransparency = 1
			L.Size = UDim2.new(1, -16, 1, 0)
			L.Position = UDim2.new(0, 16, 0, 0)
			L.Font = Enum.Font.Gotham
			L.Text = text
			L.TextColor3 = C.TEXT2
			L.TextSize = 11
			L.TextXAlignment = Enum.TextXAlignment.Left
			L.ZIndex = 4
			L.Parent = Row

			local ctrl = {}
			function ctrl:Set(v) L.Text = v end
			function ctrl:Get() return L.Text end
			return ctrl
		end

		function Tab:AddSeparator(subTab)
			local frame = getFrame(subTab)
			if not frame then return end

			local Sep = Instance.new("Frame")
			Sep.BackgroundColor3 = C.DIVIDER
			Sep.BorderSizePixel = 0
			Sep.Size = UDim2.new(1, 0, 0, 1)
			Sep.ZIndex = 3
			Sep.Parent = frame
		end

		table.insert(Window._tabs, Tab)
		return Tab
	end

	return Window
end

return NeronLib
