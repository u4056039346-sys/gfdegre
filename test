		MakeCorner(SideBtn, 4)

		local AccBar = Instance.new("Frame")
		AccBar.BackgroundColor3 = C.ACCENT
		AccBar.BorderSizePixel = 0
		AccBar.Size = UDim2.new(0, 2, 0.6, 0)
		AccBar.Position = UDim2.new(0, 0, 0.2, 0)
		AccBar.Visible = false
		AccBar.ZIndex = 5
		AccBar.Parent = SideBtn
		MakeCorner(AccBar, 2)

		SideBtn.MouseEnter:Connect(function()
			if Window._activeSideBtn ~= SideBtn then Tween(SideBtn, {BackgroundTransparency = 0.82}, 0.12) end
		end)
		SideBtn.MouseLeave:Connect(function()
			if Window._activeSideBtn ~= SideBtn then Tween(SideBtn, {BackgroundTransparency = 1}, 0.12) end
		end)

		local function buildSubTabBtns()
			for _, c in ipairs(SubRow:GetChildren()) do
				if c:IsA("TextButton") then c:Destroy() end
			end
			for _, stName in ipairs(SUB_TABS) do
				local stData = Tab._subTabs[stName]

				local Btn = Instance.new("TextButton")
				Btn.BackgroundTransparency = 1
				Btn.BorderSizePixel = 0
				Btn.Size = UDim2.new(0, 0, 1, 0)
				Btn.AutomaticSize = Enum.AutomaticSize.X
				Btn.Font = Enum.Font.GothamBold
				Btn.Text = stName
				Btn.TextColor3 = C.TEXT2
				Btn.TextSize = 11
				Btn.ZIndex = 4
				Btn.Parent = SubRow
				MakePadding(Btn, 0, 0, 4, 4)

				local Underline = Instance.new("Frame")
				Underline.BackgroundColor3 = C.ACCENT
				Underline.BorderSizePixel = 0
				Underline.Size = UDim2.new(1, 0, 0, 2)
				Underline.Position = UDim2.new(0, 0, 1, -2)
				Underline.Visible = false
				Underline.ZIndex = 5
				Underline.Parent = Btn

				stData.btn = Btn
				stData.underline = Underline

				local sn = stName
				Btn.MouseButton1Click:Connect(function()
					Tab:_selectST(sn)
				end)
			end
		end

		function Tab:_selectST(stName)
			local stData = Tab._subTabs[stName]
			if not stData or not stData.btn then return end

			if Tab._activeSTBtn then
				Tween(Tab._activeSTBtn, {TextColor3 = C.TEXT2}, 0.1)
				if Tab._subTabs[Tab._activeST] then
					Tab._subTabs[Tab._activeST].underline.Visible = false
				end
			end
			if Tab._activeST then
				Tab._subTabs[Tab._activeST].frame.Visible = false
			end

			Tab._activeST = stName
			Tab._activeSTBtn = stData.btn
			Tween(stData.btn, {TextColor3 = C.TEXT1}, 0.1)
			stData.underline.Visible = true
			stData.frame.Visible = true
		end

		SideBtn.MouseButton1Click:Connect(function()
			if Window._activeSideBtn and Window._activeSideBtn ~= SideBtn then
				Tween(Window._activeSideBtn, {BackgroundTransparency = 1, TextColor3 = C.TEXT3}, 0.15)
				for _, c in ipairs(Window._activeSideBtn:GetChildren()) do
					if c:IsA("Frame") then c.Visible = false end
				end
				-- Hide all other tabs' frames
				for _, tab in ipairs(Window._tabs) do
					if tab ~= Tab then
						for _, stName in ipairs(SUB_TABS) do
							if tab._subTabs[stName] then
								tab._subTabs[stName].frame.Visible = false
							end
						end
						tab._activeST = nil
						tab._activeSTBtn = nil
					end
				end
			end

			Window._activeSideBtn = SideBtn
			Tween(SideBtn, {BackgroundTransparency = 0.7, TextColor3 = C.TEXT1}, 0.15)
			AccBar.Visible = true

			TopTitle.Text = name
			TopDesc.Text = Tab._desc

			buildSubTabBtns()

			Tab._activeST = nil
			Tab._activeSTBtn = nil
			Tab:_selectST("General")
		end)

		local function getFrame(subTab)
			local st = subTab or "General"
			local stData = Tab._subTabs[st]
			return stData and stData.frame or nil
		end

