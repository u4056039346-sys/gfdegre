	--------------------------------------------------------------------
	-- Switch which tab is visible in the content area
	--------------------------------------------------------------------
	local function showTab(tab)
		-- Hide all tab containers
		for _, t in ipairs(Window._tabs) do
			t._container.Visible = false
			t._activeST    = nil
			t._activeSTBtn = nil
		end
		-- Show the selected tab's container
		tab._container.Visible = true
		Window._activeTab = tab
	end

	--------------------------------------------------------------------
	-- Build sub-tab row buttons for a given tab
	--------------------------------------------------------------------
	local function buildSubTabBtns(tab)
		-- Destroy old buttons
		for _, child in ipairs(SubRow:GetChildren()) do
			if child:IsA("TextButton") then child:Destroy() end
		end
		-- Create new ones
		for _, stName in ipairs(SUB_TABS) do
			local stData = tab._subTabs[stName]

			local Btn = Instance.new("TextButton")
			Btn.BackgroundTransparency = 1
			Btn.BorderSizePixel = 0
			Btn.Size = UDim2.new(0, 0, 1, 0)
			Btn.AutomaticSize = Enum.AutomaticSize.X
			Btn.Font = Enum.Font.GothamBold
			Btn.Text = stName
			Btn.TextColor3 = C.TEXT2
			Btn.TextSize   = 11
			Btn.ZIndex = 4
			Btn.Parent = SubRow
			MakePadding(Btn, 0, 0, 4, 4)

			local Underline = Instance.new("Frame")
			Underline.BackgroundColor3 = C.ACCENT
			Underline.BorderSizePixel  = 0
			Underline.Size     = UDim2.new(1, 0, 0, 2)
			Underline.Position = UDim2.new(0, 0, 1, -2)
			Underline.Visible  = false
			Underline.ZIndex   = 5
			Underline.Parent   = Btn

			stData.btn       = Btn
			stData.underline = Underline

			local capturedName = stName
			Btn.MouseButton1Click:Connect(function()
				tab:_selectSubTab(capturedName)
			end)
		end
	end

	--------------------------------------------------------------------
	-- AddCategory
	--------------------------------------------------------------------
	function Window:AddCategory(categoryName)
		local Category = {}

		local CatLabel = Instance.new("TextLabel")
		CatLabel.BackgroundTransparency = 1
		CatLabel.Size = UDim2.new(1, 0, 0, 20)
		CatLabel.Font = Enum.Font.GothamBold
		CatLabel.Text = categoryName
		CatLabel.TextColor3 = C.CAT_LABEL
		CatLabel.TextSize   = 9
		CatLabel.TextXAlignment = Enum.TextXAlignment.Left
		CatLabel.ZIndex = 4
		CatLabel.Parent = SideScroll
		MakePadding(CatLabel, 6, 0, 14, 0)

		--------------------------------------------------------------------
		-- Category:AddTab
		--------------------------------------------------------------------
		function Category:AddTab(name, icon, desc)
			local Tab = {}
			Tab._name        = name
			Tab._desc        = desc or ""
			Tab._subTabs     = {}
			Tab._activeST    = nil
			Tab._activeSTBtn = nil

			-- Each tab gets its OWN container frame inside Content
			-- Only the active tab's container is visible at a time
			local TabContainer = Instance.new("Frame")
			TabContainer.Name                = "TabContainer_" .. name
			TabContainer.BackgroundTransparency = 1
			TabContainer.BorderSizePixel     = 0
			TabContainer.Size                = UDim2.new(1, 0, 0, 0)
			TabContainer.AutomaticSize       = Enum.AutomaticSize.Y
			TabContainer.Visible             = false
			TabContainer.ZIndex              = 3
			TabContainer.Parent              = Content
			MakeList(TabContainer, 4)
			Tab._container = TabContainer

			-- Build one frame per sub-tab inside the container
			for _, stName in ipairs(SUB_TABS) do
				local F = Instance.new("Frame")
				F.Name                = "STFrame_" .. stName
				F.BackgroundTransparency = 1
				F.BorderSizePixel     = 0
				F.Size                = UDim2.new(1, 0, 0, 0)
				F.AutomaticSize       = Enum.AutomaticSize.Y
				F.Visible             = false
				F.ZIndex              = 3
				F.Parent              = TabContainer
				MakeList(F, 4)
				Tab._subTabs[stName] = {frame = F, btn = nil, underline = nil}
			end

			-- _selectSubTab
			function Tab:_selectSubTab(stName)
				local stData = Tab._subTabs[stName]
				if not stData or not stData.btn then return end

				if Tab._activeSTBtn then
					Tween(Tab._activeSTBtn, {TextColor3 = C.TEXT2}, 0.1)
				end
				if Tab._activeST and Tab._subTabs[Tab._activeST] then
					Tab._subTabs[Tab._activeST].underline.Visible = false
					Tab._subTabs[Tab._activeST].frame.Visible     = false
				end

				Tab._activeST    = stName
				Tab._activeSTBtn = stData.btn
				Tween(stData.btn, {TextColor3 = C.TEXT1}, 0.1)
				stData.underline.Visible = true
				stData.frame.Visible     = true
			end

			-- Sidebar button
			local SideBtn = Instance.new("TextButton")
			SideBtn.BackgroundColor3    = C.ITEM
			SideBtn.BackgroundTransparency = 1
			SideBtn.BorderSizePixel     = 0
			SideBtn.Size   = UDim2.new(1, 0, 0, 28)
			SideBtn.Font   = Enum.Font.Gotham
			SideBtn.Text   = ""
			SideBtn.ZIndex = 4
			SideBtn.Parent = SideScroll
			MakeCorner(SideBtn, 4)

			local IconLbl = Instance.new("TextLabel")
			IconLbl.BackgroundTransparency = 1
			IconLbl.Size     = UDim2.new(0, 18, 1, 0)
			IconLbl.Position = UDim2.new(0, 10, 0, 0)
			IconLbl.Font     = Enum.Font.Gotham
			IconLbl.Text     = icon or "•"
			IconLbl.TextColor3 = C.TEXT3
			IconLbl.TextSize   = 12
			IconLbl.ZIndex   = 5
			IconLbl.Parent   = SideBtn

			local NameLbl = Instance.new("TextLabel")
			NameLbl.BackgroundTransparency = 1
			NameLbl.Size     = UDim2.new(1, -34, 1, 0)
			NameLbl.Position = UDim2.new(0, 30, 0, 0)
			NameLbl.Font     = Enum.Font.Gotham
			NameLbl.Text     = name
			NameLbl.TextColor3   = C.TEXT2
			NameLbl.TextSize     = 11
			NameLbl.TextXAlignment = Enum.TextXAlignment.Left
			NameLbl.ZIndex   = 5
			NameLbl.Parent   = SideBtn

			local AccBar = Instance.new("Frame")
			AccBar.BackgroundColor3 = C.ACCENT
			AccBar.BorderSizePixel  = 0
			AccBar.Size     = UDim2.new(0, 2, 0.6, 0)
			AccBar.Position = UDim2.new(0, 0, 0.2, 0)
			AccBar.Visible  = false
			AccBar.ZIndex   = 5
			AccBar.Parent   = SideBtn
			MakeCorner(AccBar, 2)

			SideBtn.MouseEnter:Connect(function()
				if Window._activeSideBtn ~= SideBtn then
					Tween(SideBtn,  {BackgroundTransparency = 0.82}, 0.12)
					Tween(NameLbl,  {TextColor3 = C.TEXT1},          0.12)
					Tween(IconLbl,  {TextColor3 = C.TEXT2},          0.12)
				end
			end)
			SideBtn.MouseLeave:Connect(function()
				if Window._activeSideBtn ~= SideBtn then
					Tween(SideBtn,  {BackgroundTransparency = 1},    0.12)
					Tween(NameLbl,  {TextColor3 = C.TEXT2},          0.12)
					Tween(IconLbl,  {TextColor3 = C.TEXT3},          0.12)
				end
			end)

			SideBtn.MouseButton1Click:Connect(function()
				if Window._activeSideBtn == SideBtn then return end

				-- Deselect old sidebar button
				if Window._activeSideBtn then
					local prev = Window._activeSideBtn
					Tween(prev, {BackgroundTransparency = 1}, 0.15)
					local prevName = prev:FindFirstChild("NameLbl")
					local prevIcon = prev:FindFirstChild("IconLbl")
					local prevAcc  = prev:FindFirstChild("AccBar")
					if prevName then Tween(prevName, {TextColor3 = C.TEXT2}, 0.15) end
					if prevIcon then Tween(prevIcon, {TextColor3 = C.TEXT3}, 0.15) end
					if prevAcc  then prevAcc.Visible = false end
				end

				-- Activate this button
				Window._activeSideBtn = SideBtn
				Tween(SideBtn, {BackgroundTransparency = 0.75}, 0.15)
				Tween(NameLbl, {TextColor3 = C.TEXT1},          0.15)
				Tween(IconLbl, {TextColor3 = C.ACCENT_DIM},     0.15)
				AccBar.Visible = true

				-- Update top bar
				TopTitle.Text = name
				TopDesc.Text  = Tab._desc

				-- Show this tab's content, hide everything else
				showTab(Tab)

				-- Build sub-tab row for this tab
				buildSubTabBtns(Tab)

				-- Select General
				Tab._activeST    = nil
				Tab._activeSTBtn = nil
				Tab:_selectSubTab("General")
			end)

			-- Helper: get the right sub-tab frame
			local function getFrame(subTab)
				local st = subTab or "General"
				local stData = Tab._subTabs[st]
				return stData and stData.frame or nil
			end

			----------------------------------------------------------------
			-- Tab:AddToggle
			----------------------------------------------------------------
			function Tab:AddToggle(label, description, default, callback, subTab)
				local frame = getFrame(subTab)
				if not frame then return end
				local isOn = default or false

				local Row = Instance.new("Frame")
				Row.BackgroundColor3 = C.ITEM
				Row.BorderSizePixel  = 0
				Row.Size   = UDim2.new(1, 0, 0, 49)
				Row.ZIndex = 3
				Row.Parent = frame
				MakeCorner(Row, 4)

				local LabelTxt = Instance.new("TextLabel")
				LabelTxt.BackgroundTransparency = 1
				LabelTxt.Size     = UDim2.new(1, -60, 0, 22)
				LabelTxt.Position = UDim2.new(0, 16, 0, 6)
				LabelTxt.Font     = Enum.Font.GothamBold
				LabelTxt.Text     = label
				LabelTxt.TextColor3   = C.TEXT1
				LabelTxt.TextSize     = 12
				LabelTxt.TextXAlignment = Enum.TextXAlignment.Left
				LabelTxt.ZIndex   = 4
				LabelTxt.Parent   = Row

				if description and description ~= "" then
					local DescTxt = Instance.new("TextLabel")
					DescTxt.BackgroundTransparency = 1
					DescTxt.Size     = UDim2.new(1, -60, 0, 18)
					DescTxt.Position = UDim2.new(0, 16, 0, 26)
					DescTxt.Font     = Enum.Font.Gotham
					DescTxt.Text     = description
					DescTxt.TextColor3   = C.TEXT3
					DescTxt.TextSize     = 10
					DescTxt.TextXAlignment = Enum.TextXAlignment.Left
					DescTxt.TextWrapped  = true
					DescTxt.ZIndex   = 4
					DescTxt.Parent   = Row
				end

				local ToggleBG = Instance.new("Frame")
				ToggleBG.BackgroundColor3 = C.TOG_BG
				ToggleBG.BorderSizePixel  = 0
				ToggleBG.Size     = UDim2.new(0, 38, 0, 20)
				ToggleBG.Position = UDim2.new(1, -54, 0.5, -10)
				ToggleBG.ZIndex   = 4
				ToggleBG.Parent   = Row
				MakeCorner(ToggleBG, 10)

				local Knob = Instance.new("TextButton")
				Knob.BackgroundColor3 = isOn and C.TOG_ON or C.TOG_OFF
				Knob.BorderSizePixel  = 0
				Knob.Size     = UDim2.new(0, 16, 0, 16)
				Knob.Position = isOn and UDim2.new(0, 18, 0.5, -8) or UDim2.new(1, -34, 0.5, -8)
				Knob.Text     = ""
				Knob.ZIndex   = 5
				Knob.Parent   = ToggleBG
				MakeCorner(Knob, 8)

				local Dot = Instance.new("Frame")
				Dot.BackgroundColor3 = C.TOG_BG
				Dot.BorderSizePixel  = 0
				Dot.Size     = UDim2.new(0, 8, 0, 8)
				Dot.Position = UDim2.new(0.5, -4, 0.5, -4)
				Dot.ZIndex   = 6
				Dot.Parent   = Knob
				MakeCorner(Dot, 4)

				local function updateToggle()
					if isOn then
						Tween(Knob, {Position = UDim2.new(0, 18, 0.5, -8),    BackgroundColor3 = C.TOG_ON},  0.2)
					else
						Tween(Knob, {Position = UDim2.new(1, -34, 0.5, -8),   BackgroundColor3 = C.TOG_OFF}, 0.2)
					end
				end

				Knob.MouseButton1Click:Connect(function()
					isOn = not isOn
					updateToggle()
					if callback then callback(isOn) end
				end)

				local ctrl = {}
				function ctrl:Set(val) isOn = val updateToggle() if callback then callback(isOn) end end
				function ctrl:Get() return isOn end
				return ctrl
			end

			----------------------------------------------------------------
			-- Tab:AddButton
			----------------------------------------------------------------
			function Tab:AddButton(label, description, callback, subTab)
				if type(description) == "function" then
					subTab = callback; callback = description; description = nil
				end
				local frame = getFrame(subTab)
				if not frame then return end

				local Row = Instance.new("TextButton")
				Row.BackgroundColor3 = C.ITEM
				Row.BorderSizePixel  = 0
				Row.Size   = UDim2.new(1, 0, 0, description and 49 or 36)
				Row.Font   = Enum.Font.GothamBold
				Row.Text   = ""
				Row.ZIndex = 3
				Row.Parent = frame
				MakeCorner(Row, 4)

				local LabelTxt = Instance.new("TextLabel")
				LabelTxt.BackgroundTransparency = 1
				LabelTxt.Size     = UDim2.new(1, -40, 0, 22)
				LabelTxt.Position = UDim2.new(0, 16, 0, description and 6 or 7)
				LabelTxt.Font     = Enum.Font.GothamBold
				LabelTxt.Text     = label
				LabelTxt.TextColor3   = C.TEXT1
				LabelTxt.TextSize     = 12
				LabelTxt.TextXAlignment = Enum.TextXAlignment.Left
				LabelTxt.ZIndex   = 4
				LabelTxt.Parent   = Row

				if description then
					local DescTxt = Instance.new("TextLabel")
					DescTxt.BackgroundTransparency = 1
					DescTxt.Size     = UDim2.new(1, -40, 0, 16)
					DescTxt.Position = UDim2.new(0, 16, 0, 27)
					DescTxt.Font     = Enum.Font.Gotham
					DescTxt.Text     = description
					DescTxt.TextColor3   = C.TEXT3
					DescTxt.TextSize     = 10
					DescTxt.TextXAlignment = Enum.TextXAlignment.Left
					DescTxt.ZIndex   = 4
					DescTxt.Parent   = Row
				end

				local Arrow = Instance.new("TextLabel")
				Arrow.BackgroundTransparency = 1
				Arrow.Size     = UDim2.new(0, 20, 0, 20)
				Arrow.Position = UDim2.new(1, -28, 0.5, -10)
				Arrow.Font     = Enum.Font.GothamBold
				Arrow.Text     = "›"
				Arrow.TextColor3 = C.ACCENT_DIM
				Arrow.TextSize   = 18
				Arrow.ZIndex   = 4
				Arrow.Parent   = Row

				Row.MouseEnter:Connect(function() Tween(Row, {BackgroundColor3 = C.ITEM_HOVER}, 0.1) end)
				Row.MouseLeave:Connect(function() Tween(Row, {BackgroundColor3 = C.ITEM},       0.1) end)
				Row.MouseButton1Click:Connect(function() if callback then callback() end end)
			end

			----------------------------------------------------------------
			-- Tab:AddSlider
			----------------------------------------------------------------
			function Tab:AddSlider(label, description, min, max, default, callback, subTab)
				if type(description) == "number" then
					subTab = callback; callback = default; default = max; max = min; min = description; description = nil
				end
				local frame = getFrame(subTab)
				if not frame then return end
				local value = default or min

				local Row = Instance.new("Frame")
				Row.BackgroundColor3 = C.ITEM
				Row.BorderSizePixel  = 0
				Row.Size   = UDim2.new(1, 0, 0, 60)
				Row.ZIndex = 3
				Row.Parent = frame
				MakeCorner(Row, 4)

				local LabelTxt = Instance.new("TextLabel")
				LabelTxt.BackgroundTransparency = 1
				LabelTxt.Size     = UDim2.new(1, -70, 0, 20)
				LabelTxt.Position = UDim2.new(0, 16, 0, 6)
				LabelTxt.Font     = Enum.Font.GothamBold
				LabelTxt.Text     = label
				LabelTxt.TextColor3   = C.TEXT1
				LabelTxt.TextSize     = 12
				LabelTxt.TextXAlignment = Enum.TextXAlignment.Left
				LabelTxt.ZIndex   = 4
				LabelTxt.Parent   = Row

				local ValueTxt = Instance.new("TextLabel")
				ValueTxt.BackgroundTransparency = 1
				ValueTxt.Size     = UDim2.new(0, 50, 0, 20)
				ValueTxt.Position = UDim2.new(1, -64, 0, 6)
				ValueTxt.Font     = Enum.Font.GothamBold
				ValueTxt.Text     = tostring(value)
				ValueTxt.TextColor3   = C.ACCENT_DIM
				ValueTxt.TextSize     = 12
				ValueTxt.TextXAlignment = Enum.TextXAlignment.Right
				ValueTxt.ZIndex   = 4
				ValueTxt.Parent   = Row

				if description then
					local DescTxt = Instance.new("TextLabel")
					DescTxt.BackgroundTransparency = 1
					DescTxt.Size     = UDim2.new(1, -16, 0, 14)
					DescTxt.Position = UDim2.new(0, 16, 0, 25)
					DescTxt.Font     = Enum.Font.Gotham
					DescTxt.Text     = description
					DescTxt.TextColor3 = C.TEXT3
					DescTxt.TextSize   = 10
					DescTxt.ZIndex   = 4
					DescTxt.Parent   = Row
				end

				local TrackBG = Instance.new("Frame")
				TrackBG.BackgroundColor3 = Color3.fromRGB(25, 25, 32)
				TrackBG.BorderSizePixel  = 0
				TrackBG.Size     = UDim2.new(1, -32, 0, 4)
				TrackBG.Position = UDim2.new(0, 16, 1, -18)
				TrackBG.ZIndex   = 4
				TrackBG.Parent   = Row
				MakeCorner(TrackBG, 2)

				local Fill = Instance.new("Frame")
				Fill.BackgroundColor3 = C.ACCENT
				Fill.BorderSizePixel  = 0
				Fill.Size   = UDim2.new((value - min) / (max - min), 0, 1, 0)
				Fill.ZIndex = 5
				Fill.Parent = TrackBG
				MakeCorner(Fill, 2)

				local SliderKnob = Instance.new("TextButton")
				SliderKnob.BackgroundColor3 = C.TEXT1
				SliderKnob.BorderSizePixel  = 0
				SliderKnob.Size     = UDim2.new(0, 12, 0, 12)
				SliderKnob.Position = UDim2.new((value - min) / (max - min), -6, 0.5, -6)
				SliderKnob.Text     = ""
				SliderKnob.ZIndex   = 6
				SliderKnob.Parent   = TrackBG
				MakeCorner(SliderKnob, 6)

				local draggingSlider = false
				SliderKnob.MouseButton1Down:Connect(function() draggingSlider = true end)
				UserInputService.InputEnded:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1 then draggingSlider = false end
				end)
				UserInputService.InputChanged:Connect(function(i)
					if draggingSlider and i.UserInputType == Enum.UserInputType.MouseMovement then
						local pct = math.clamp((i.Position.X - TrackBG.AbsolutePosition.X) / TrackBG.AbsoluteSize.X, 0, 1)
						value = math.floor(min + (max - min) * pct + 0.5)
						ValueTxt.Text        = tostring(value)
						Fill.Size            = UDim2.new(pct, 0, 1, 0)
						SliderKnob.Position  = UDim2.new(pct, -6, 0.5, -6)
						if callback then callback(value) end
					end
				end)

				local ctrl = {}
				function ctrl:Set(v)
					value = math.clamp(v, min, max)
					local pct = (value - min) / (max - min)
					ValueTxt.Text       = tostring(value)
					Fill.Size           = UDim2.new(pct, 0, 1, 0)
					SliderKnob.Position = UDim2.new(pct, -6, 0.5, -6)
					if callback then callback(value) end
				end
				function ctrl:Get() return value end
				return ctrl
			end

			----------------------------------------------------------------
			-- Tab:AddTextbox
			----------------------------------------------------------------
			function Tab:AddTextbox(label, placeholder, callback, subTab)
				local frame = getFrame(subTab)
				if not frame then return end

				local Row = Instance.new("Frame")
				Row.BackgroundColor3 = C.ITEM
				Row.BorderSizePixel  = 0
				Row.Size   = UDim2.new(1, 0, 0, 56)
				Row.ZIndex = 3
				Row.Parent = frame
				MakeCorner(Row, 4)

				local LabelTxt = Instance.new("TextLabel")
				LabelTxt.BackgroundTransparency = 1
				LabelTxt.Size     = UDim2.new(1, -16, 0, 20)
				LabelTxt.Position = UDim2.new(0, 16, 0, 5)
				LabelTxt.Font     = Enum.Font.GothamBold
				LabelTxt.Text     = label
				LabelTxt.TextColor3   = C.TEXT1
				LabelTxt.TextSize     = 12
				LabelTxt.TextXAlignment = Enum.TextXAlignment.Left
				LabelTxt.ZIndex   = 4
				LabelTxt.Parent   = Row

				local InputFrame = Instance.new("Frame")
				InputFrame.BackgroundColor3 = C.INPUT_BG
				InputFrame.BorderSizePixel  = 0
				InputFrame.Size     = UDim2.new(1, -32, 0, 22)
				InputFrame.Position = UDim2.new(0, 16, 0, 28)
				InputFrame.ZIndex   = 4
				InputFrame.Parent   = Row
				MakeCorner(InputFrame, 4)

				local InputBox = Instance.new("TextBox")
				InputBox.BackgroundTransparency = 1
				InputBox.Size     = UDim2.new(1, -12, 1, 0)
				InputBox.Position = UDim2.new(0, 6, 0, 0)
				InputBox.Font     = Enum.Font.Gotham
				InputBox.PlaceholderText  = placeholder or ""
				InputBox.PlaceholderColor3 = C.TEXT3
				InputBox.Text     = ""
				InputBox.TextColor3   = C.TEXT1
				InputBox.TextSize     = 11
				InputBox.TextXAlignment = Enum.TextXAlignment.Left
				InputBox.ClearTextOnFocus = false
				InputBox.ZIndex   = 5
				InputBox.Parent   = InputFrame

				InputBox.FocusLost:Connect(function(enterPressed)
					if callback then callback(InputBox.Text, enterPressed) end
				end)

				local ctrl = {}
				function ctrl:Set(v) InputBox.Text = v end
				function ctrl:Get() return InputBox.Text end
				return ctrl
			end

			----------------------------------------------------------------
			-- Tab:AddDropdown
			----------------------------------------------------------------
			function Tab:AddDropdown(label, options, default, callback, subTab)
				if type(default) == "function" then
					subTab = callback; callback = default; default = options[1]
				end
				local frame = getFrame(subTab)
				if not frame then return end
				local selected = default or options[1]
				local open = false

				local Row = Instance.new("Frame")
				Row.BackgroundColor3  = C.ITEM
				Row.BorderSizePixel   = 0
				Row.Size              = UDim2.new(1, 0, 0, 49)
				Row.ClipsDescendants  = false
				Row.ZIndex            = 10
				Row.Parent            = frame
				MakeCorner(Row, 4)

				local LabelTxt = Instance.new("TextLabel")
				LabelTxt.BackgroundTransparency = 1
				LabelTxt.Size     = UDim2.new(1, -16, 0, 20)
				LabelTxt.Position = UDim2.new(0, 16, 0, 6)
				LabelTxt.Font     = Enum.Font.GothamBold
				LabelTxt.Text     = label
				LabelTxt.TextColor3   = C.TEXT1
				LabelTxt.TextSize     = 12
				LabelTxt.TextXAlignment = Enum.TextXAlignment.Left
				LabelTxt.ZIndex   = 11
				LabelTxt.Parent   = Row

				local DropBtn = Instance.new("TextButton")
				DropBtn.BackgroundColor3 = C.INPUT_BG
				DropBtn.BorderSizePixel  = 0
				DropBtn.Size     = UDim2.new(1, -32, 0, 22)
				DropBtn.Position = UDim2.new(0, 16, 0, 22)
				DropBtn.Font     = Enum.Font.Gotham
				DropBtn.Text     = selected
				DropBtn.TextColor3   = C.TEXT2
				DropBtn.TextSize     = 11
				DropBtn.TextXAlignment = Enum.TextXAlignment.Left
				DropBtn.ZIndex   = 11
				DropBtn.Parent   = Row
				MakeCorner(DropBtn, 4)
				MakePadding(DropBtn, 0, 0, 8, 8)

				local DropArrow = Instance.new("TextLabel")
				DropArrow.BackgroundTransparency = 1
				DropArrow.Size     = UDim2.new(0, 20, 1, 0)
				DropArrow.Position = UDim2.new(1, -22, 0, 0)
				DropArrow.Font     = Enum.Font.GothamBold
				DropArrow.Text     = "▾"
				DropArrow.TextColor3 = C.TEXT3
				DropArrow.TextSize   = 12
				DropArrow.ZIndex   = 12
				DropArrow.Parent   = DropBtn

				local DropList = Instance.new("Frame")
				DropList.BackgroundColor3 = C.DROPDOWN_BG
				DropList.BorderSizePixel  = 0
				DropList.Size     = UDim2.new(1, -32, 0, #options * 26 + 4)
				DropList.Position = UDim2.new(0, 16, 0, 47)
				DropList.Visible  = false
				DropList.ZIndex   = 20
				DropList.Parent   = Row
				MakeCorner(DropList, 4)
				MakePadding(DropList, 2, 2, 4, 4)
				MakeList(DropList, 2)

				for _, opt in ipairs(options) do
					local OptBtn = Instance.new("TextButton")
					OptBtn.BackgroundColor3    = C.DROPDOWN_BG
					OptBtn.BackgroundTransparency = 1
					OptBtn.BorderSizePixel     = 0
					OptBtn.Size   = UDim2.new(1, 0, 0, 22)
					OptBtn.Font   = Enum.Font.Gotham
					OptBtn.Text   = opt
					OptBtn.TextColor3 = opt == selected and C.TEXT1 or C.TEXT2
					OptBtn.TextSize   = 11
					OptBtn.TextXAlignment = Enum.TextXAlignment.Left
					OptBtn.ZIndex = 21
					OptBtn.Parent = DropList
					MakePadding(OptBtn, 0, 0, 6, 6)
					MakeCorner(OptBtn, 3)

					OptBtn.MouseEnter:Connect(function() Tween(OptBtn, {BackgroundTransparency = 0.7}, 0.1) end)
					OptBtn.MouseLeave:Connect(function() Tween(OptBtn, {BackgroundTransparency = 1},   0.1) end)
					OptBtn.MouseButton1Click:Connect(function()
						selected = opt
						DropBtn.Text = opt
						for _, o in ipairs(DropList:GetChildren()) do
							if o:IsA("TextButton") then
								o.TextColor3 = o.Text == selected and C.TEXT1 or C.TEXT2
							end
						end
						open = false
						DropList.Visible = false
						Tween(DropArrow, {Rotation = 0}, 0.15)
						if callback then callback(selected) end
					end)
				end

				DropBtn.MouseButton1Click:Connect(function()
					open = not open
					DropList.Visible = open
					Tween(DropArrow, {Rotation = open and 180 or 0}, 0.15)
				end)

				local ctrl = {}
				function ctrl:Set(v) selected = v DropBtn.Text = v if callback then callback(selected) end end
				function ctrl:Get() return selected end
				return ctrl
			end

			----------------------------------------------------------------
			-- Tab:AddLabel
			----------------------------------------------------------------
			function Tab:AddLabel(text, subTab)
				local frame = getFrame(subTab)
				if not frame then return end

				local Row = Instance.new("Frame")
				Row.BackgroundColor3 = C.ITEM
				Row.BorderSizePixel  = 0
				Row.Size   = UDim2.new(1, 0, 0, 32)
				Row.ZIndex = 3
				Row.Parent = frame
				MakeCorner(Row, 4)

				local LabelTxt = Instance.new("TextLabel")
				LabelTxt.BackgroundTransparency = 1
				LabelTxt.Size     = UDim2.new(1, -16, 1, 0)
				LabelTxt.Position = UDim2.new(0, 16, 0, 0)
				LabelTxt.Font     = Enum.Font.Gotham
				LabelTxt.Text     = text
				LabelTxt.TextColor3   = C.TEXT2
				LabelTxt.TextSize     = 11
				LabelTxt.TextXAlignment = Enum.TextXAlignment.Left
				LabelTxt.ZIndex   = 4
				LabelTxt.Parent   = Row

				local ctrl = {}
				function ctrl:Set(v) LabelTxt.Text = v end
				function ctrl:Get() return LabelTxt.Text end
				return ctrl
			end

			----------------------------------------------------------------
			-- Tab:AddSeparator
			----------------------------------------------------------------
			function Tab:AddSeparator(subTab)
				local frame = getFrame(subTab)
				if not frame then return end

				local Sep = Instance.new("Frame")
				Sep.BackgroundColor3 = C.DIVIDER
				Sep.BorderSizePixel  = 0
				Sep.Size   = UDim2.new(1, 0, 0, 1)
				Sep.ZIndex = 3
				Sep.Parent = frame
			end

			table.insert(Window._tabs, Tab)
			return Tab
		end

		return Category
	end

	return Window
end

return NeronLib
