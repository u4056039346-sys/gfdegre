			Dot.Position = UDim2.new(0.5, -4, 0.5, -4)
			Dot.ZIndex = 6
			Dot.Parent = Knob
			MakeCorner(Dot, 4)

			local function update()
				Tween(Knob, {
					Position = isOn and UDim2.new(0, 18, 0.5, -8) or UDim2.new(1, -34, 0.5, -8),
					BackgroundColor3 = isOn and C.TOG_ON or C.TOG_OFF
				}, 0.2)
			end
			local function toggle()
				isOn = not isOn; update()
				if callback then callback(isOn) end
			end

			Knob.MouseButton1Click:Connect(toggle)

			local ctrl = {}
			function ctrl:Set(val) isOn = val update() if callback then callback(isOn) end end
			function ctrl:Get() return isOn end
			return ctrl
		end

