			_desc = desc or "",
			_subTabs = {},
			_activeST = nil,
			_activeSTBtn = nil,
		}

		-- Build the 3 sub-tab content frames IMMEDIATELY so elements can be added right away
		for _, stName in ipairs(SUB_TABS) do
			local F = Instance.new("Frame")
			F.BackgroundTransparency = 1
			F.BorderSizePixel = 0
			F.Size = UDim2.new(1, 0, 0, 0)
			F.AutomaticSize = Enum.AutomaticSize.Y
			F.Visible = false
			F.ZIndex = 3
			F.Parent = Content
			MakeList(F, 4)
			Tab._subTabs[stName] = {frame = F, btn = nil, underline = nil}
		end

		-- Sidebar button
		local SideBtn = Instance.new("TextButton")
		SideBtn.BackgroundColor3 = C.ITEM
		SideBtn.BackgroundTransparency = 1
		SideBtn.BorderSizePixel = 0
		SideBtn.Size = UDim2.new(1, 0, 0, 32)
		SideBtn.Font = Enum.Font.GothamBold
		SideBtn.Text = name
