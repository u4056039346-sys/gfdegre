	-----------------------------------------------------------------
	-- AddTab
	-----------------------------------------------------------------
	function Window:AddTab(name, description)
		local Tab = {}
		Tab._name = name
		Tab._description = description or ""
		Tab._subTabs = {}
		Tab._activeSubTab = nil
		Tab._activeSubTabBtn = nil
		Tab._frames = {}

		-- Sidebar button
		local SideBtn = Instance.new("TextButton")
		SideBtn.Name = name
		SideBtn.BackgroundColor3 = C.ITEM
		SideBtn.BackgroundTransparency = 1
		SideBtn.BorderSizePixel = 0
		SideBtn.Size = UDim2.new(1, 0, 0, 32)
		SideBtn.Font = Enum.Font.GothamBold
		SideBtn.Text = name
		SideBtn.TextColor3 = C.TEXT_DIM
		SideBtn.TextSize = 11
		SideBtn.TextXAlignment = Enum.TextXAlignment.Left
		SideBtn.ZIndex = 4
		SideBtn.Parent = Window._sidebar
		MakePadding(SideBtn, 0, 0, 10, 6)
		MakeCorner(SideBtn, 4)

		-- Accent bar on left
		local AccentBar = Instance.new("Frame")
		AccentBar.BackgroundColor3 = C.ACCENT
		AccentBar.BorderSizePixel = 0
		AccentBar.Size = UDim2.new(0, 2, 0.6, 0)
		AccentBar.Position = UDim2.new(0, 0, 0.2, 0)
		AccentBar.Visible = false
		AccentBar.ZIndex = 5
		AccentBar.Parent = SideBtn
		MakeCorner(AccentBar, 2)

		-- Hover
		SideBtn.MouseEnter:Connect(function()
			if Window._activeSidebarBtn ~= SideBtn then
				Tween(SideBtn, {BackgroundTransparency = 0.85}, 0.15)
			end
		end)
		SideBtn.MouseLeave:Connect(function()
			if Window._activeSidebarBtn ~= SideBtn then
				Tween(SideBtn, {BackgroundTransparency = 1}, 0.15)
			end
		end)

		-- Create sub-tab buttons and frames per sub-tab
		local function buildSubTabBtn(stName)
			local Btn = Instance.new("TextButton")
			Btn.BackgroundTransparency = 1
			Btn.BorderSizePixel = 0
			Btn.Size = UDim2.new(0, 0, 1, 0)
			Btn.AutomaticSize = Enum.AutomaticSize.X
			Btn.Font = Enum.Font.GothamBold
			Btn.Text = stName
			Btn.TextColor3 = C.TEXT_SECONDARY
			Btn.TextSize = 11
			Btn.ZIndex = 4
			Btn.Parent = Window._subTabRow
			MakePadding(Btn, 0, 0, 4, 4)

			local Underline = Instance.new("Frame")
			Underline.BackgroundColor3 = C.ACCENT
			Underline.BorderSizePixel = 0
			Underline.Size = UDim2.new(1, 0, 0, 2)
			Underline.Position = UDim2.new(0, 0, 1, -2)
			Underline.Visible = false
			Underline.ZIndex = 5
			Underline.Parent = Btn

			-- Frame for this sub-tab's elements
			local STFrame = Instance.new("Frame")
			STFrame.Name = stName
			STFrame.BackgroundTransparency = 1
			STFrame.BorderSizePixel = 0
			STFrame.Size = UDim2.new(1, 0, 0, 0)
			STFrame.AutomaticSize = Enum.AutomaticSize.Y
			STFrame.Visible = false
			STFrame.ZIndex = 3
			STFrame.Parent = Window._contentArea
			MakeList(STFrame, 4)

			local stData = {name = stName, btn = Btn, underline = Underline, frame = STFrame}
			Tab._subTabs[stName] = stData
			Tab._frames[stName] = STFrame

			Btn.MouseButton1Click:Connect(function()
				Tab:_selectSubTab(stName)
			end)

			return stData
		end

		-- Always create General / Additional / Misc sub-tabs
		local defaultSubTabs = {"General", "Additional", "Misc"}

		SideBtn.MouseButton1Click:Connect(function()
			-- Deselect previous tab
			if Window._activeSidebarBtn then
				Tween(Window._activeSidebarBtn, {BackgroundTransparency = 1, TextColor3 = C.TEXT_DIM}, 0.15)
                local oldAccent = Window._activeSidebarBtn:FindFirstChild("AccentBar")
                if oldAccent then oldAccent.Visible = false end
				-- hide old accent bar
				for _, c in ipairs(Window._activeSidebarBtn:GetChildren()) do
					if c:IsA("Frame") then c.Visible = false end
				end
			end

			-- Activate this tab
			Window._activeSidebarBtn = SideBtn
			Tween(SideBtn, {BackgroundTransparency = 0.7, TextColor3 = C.TEXT_PRIMARY}, 0.15)
			AccentBar.Visible = true

			-- Update top bar info
			Window._topTitle.Text = name
			Window._topDesc.Text = Tab._description

			-- Clear sub-tab row
			for _, c in ipairs(Window._subTabRow:GetChildren()) do
				if c:IsA("TextButton") then c:Destroy() end
			end

			-- Clear content
			for _, c in ipairs(Window._contentArea:GetChildren()) do
				if c:IsA("Frame") or c:IsA("ScrollingFrame") then c:Destroy() end
			end
			Tab._subTabs = {}
			Tab._frames = {}

			-- Rebuild sub-tabs for this tab
			for _, stName in ipairs(defaultSubTabs) do
				buildSubTabBtn(stName)
			end

			-- Select first sub-tab
			Tab._activeSubTab = nil
			Tab._activeSubTabBtn = nil
			Tab:_selectSubTab("General")
		end)

		function Tab:_selectSubTab(stName)
			local stData = Tab._subTabs[stName]
			if not stData then return end

			-- Deselect old
			if Tab._activeSubTabBtn then
				Tween(Tab._activeSubTabBtn, {TextColor3 = C.TEXT_SECONDARY}, 0.1)
				if Tab._activeSubTabBtn:FindFirstChildOfClass("Frame") then
					Tab._activeSubTabBtn:FindFirstChildOfClass("Frame").Visible = false
				end
			end
			if Tab._activeSubTab and Tab._frames[Tab._activeSubTab] then
				Tab._frames[Tab._activeSubTab].Visible = false
			end

			-- Select new
			Tab._activeSubTab = stName
			Tab._activeSubTabBtn = stData.btn
			Tween(stData.btn, {TextColor3 = C.TEXT_PRIMARY}, 0.1)
			stData.underline.Visible = true
			if Tab._frames[stName] then
				Tab._frames[stName].Visible = true
			end
		end

		-- Element helpers — add to current active sub-tab
		local function getFrame(subTab)
			local st = subTab or Tab._activeSubTab or "General"
			return Tab._frames[st]
		end

		--------------------------------------------------------------
		-- AddToggle
		--------------------------------------------------------------
		function Tab:AddToggle(label, description, default, callback, subTab)
			local frame = getFrame(subTab)
			if not frame then return end

			local isOn = default or false
			local Row = Instance.new("Frame")
			Row.BackgroundColor3 = C.ITEM
			Row.BorderSizePixel = 0
			Row.Size = UDim2.new(1, 0, 0, 49)
			Row.ZIndex = 3
			Row.Parent = frame
			MakeCorner(Row, 4)

			local LabelTxt = Instance.new("TextLabel")
			LabelTxt.BackgroundTransparency = 1
			LabelTxt.Size = UDim2.new(1, -60, 0, 22)
			LabelTxt.Position = UDim2.new(0, 16, 0, 6)
			LabelTxt.Font = Enum.Font.GothamBold
			LabelTxt.Text = label
			LabelTxt.TextColor3 = C.TEXT_PRIMARY
			LabelTxt.TextSize = 12
			LabelTxt.TextXAlignment = Enum.TextXAlignment.Left
			LabelTxt.ZIndex = 4
			LabelTxt.Parent = Row

			if description and description ~= "" then
				local DescTxt = Instance.new("TextLabel")
				DescTxt.BackgroundTransparency = 1
				DescTxt.Size = UDim2.new(1, -60, 0, 18)
				DescTxt.Position = UDim2.new(0, 16, 0, 26)
				DescTxt.Font = Enum.Font.Gotham
				DescTxt.Text = description
				DescTxt.TextColor3 = C.TEXT_DIM
				DescTxt.TextSize = 10
				DescTxt.TextXAlignment = Enum.TextXAlignment.Left
				DescTxt.TextWrapped = true
				DescTxt.ZIndex = 4
				DescTxt.Parent = Row
			end

			-- Toggle knob container
			local ToggleBG = Instance.new("Frame")
			ToggleBG.BackgroundColor3 = C.TOGGLE_BG
			ToggleBG.BorderSizePixel = 0
			ToggleBG.Size = UDim2.new(0, 38, 0, 20)
			ToggleBG.Position = UDim2.new(1, -54, 0.5, -10)
			ToggleBG.ZIndex = 4
			ToggleBG.Parent = Row
			MakeCorner(ToggleBG, 10)

			local Knob = Instance.new("TextButton")
			Knob.BackgroundColor3 = isOn and C.TOGGLE_ON or C.TOGGLE_OFF
			Knob.BorderSizePixel = 0
			Knob.Size = UDim2.new(0, 16, 0, 16)
			Knob.Position = isOn and UDim2.new(0, 18, 0.5, -8) or UDim2.new(1, -18-16, 0.5, -8)
			Knob.Text = ""
			Knob.ZIndex = 5
			Knob.Parent = ToggleBG
			MakeCorner(Knob, 8)

			-- Inner dot
			local Dot = Instance.new("Frame")
			Dot.BackgroundColor3 = C.TOGGLE_BG
			Dot.BorderSizePixel = 0
			Dot.Size = UDim2.new(0, 8, 0, 8)
			Dot.Position = UDim2.new(0.5, -4, 0.5, -4)
			Dot.ZIndex = 6
			Dot.Parent = Knob
			MakeCorner(Dot, 4)

			local function updateToggle()
				if isOn then
					Tween(Knob, {Position = UDim2.new(0, 18, 0.5, -8), BackgroundColor3 = C.TOGGLE_ON}, 0.2)
				else
					Tween(Knob, {Position = UDim2.new(1, -34, 0.5, -8), BackgroundColor3 = C.TOGGLE_OFF}, 0.2)
				end
			end

			Knob.MouseButton1Click:Connect(function()
				isOn = not isOn
				updateToggle()
				if callback then callback(isOn) end
			end)
			Row.InputBegan:Connect(function(inp)
				if inp.UserInputType == Enum.UserInputType.MouseButton1 then
					isOn = not isOn
					updateToggle()
					if callback then callback(isOn) end
				end
			end)

			updateToggle()

			local ctrl = {}
			function ctrl:Set(val)
				isOn = val
				updateToggle()
				if callback then callback(isOn) end
			end
			function ctrl:Get() return isOn end
			return ctrl
		end

		--------------------------------------------------------------
		-- AddButton
		--------------------------------------------------------------
		function Tab:AddButton(label, description, callback, subTab)
			-- Support old signature: AddButton(label, callback)
			if type(description) == "function" then
				subTab = callback
				callback = description
				description = nil
			end
			local frame = getFrame(subTab)
			if not frame then return end

			local Row = Instance.new("TextButton")
			Row.BackgroundColor3 = C.ITEM
			Row.BorderSizePixel = 0
			Row.Size = UDim2.new(1, 0, 0, description and 49 or 36)
			Row.Font = Enum.Font.GothamBold
			Row.Text = ""
			Row.ZIndex = 3
			Row.Parent = frame
			MakeCorner(Row, 4)

			local LabelTxt = Instance.new("TextLabel")
			LabelTxt.BackgroundTransparency = 1
			LabelTxt.Size = UDim2.new(1, -16, 0, 22)
			LabelTxt.Position = UDim2.new(0, 16, 0, description and 6 or 7)
			LabelTxt.Font = Enum.Font.GothamBold
			LabelTxt.Text = label
			LabelTxt.TextColor3 = C.TEXT_PRIMARY
			LabelTxt.TextSize = 12
			LabelTxt.TextXAlignment = Enum.TextXAlignment.Left
			LabelTxt.ZIndex = 4
			LabelTxt.Parent = Row

			if description then
				local DescTxt = Instance.new("TextLabel")
				DescTxt.BackgroundTransparency = 1
				DescTxt.Size = UDim2.new(1, -16, 0, 16)
				DescTxt.Position = UDim2.new(0, 16, 0, 27)
				DescTxt.Font = Enum.Font.Gotham
				DescTxt.Text = description
				DescTxt.TextColor3 = C.TEXT_DIM
				DescTxt.TextSize = 10
				DescTxt.TextXAlignment = Enum.TextXAlignment.Left
				DescTxt.ZIndex = 4
				DescTxt.Parent = Row
			end

			-- Arrow
			local Arrow = Instance.new("TextLabel")
			Arrow.BackgroundTransparency = 1
			Arrow.Size = UDim2.new(0, 20, 0, 20)
			Arrow.Position = UDim2.new(1, -30, 0.5, -10)
			Arrow.Font = Enum.Font.GothamBold
			Arrow.Text = "›"
			Arrow.TextColor3 = C.ACCENT_DIM
			Arrow.TextSize = 18
			Arrow.ZIndex = 4
			Arrow.Parent = Row

			Row.MouseEnter:Connect(function()
