				HueHit.Size = UDim2.new(0, SV_W, 0, 18)
				HueHit.Position = UDim2.new(0, 10, 0, HUE_Y - 4)
				HueHit.Text = ""
				HueHit.ZIndex = 512
				HueHit.Parent = Panel

				local function rebuildColor()
					curColor = hsvToColor3(curH, curS, curV)
					Swatch.BackgroundColor3 = curColor
					SvFrame.BackgroundColor3 = hsvToColor3(curH, 1, 1)
					SvCursor.Position = UDim2.new(curS, 0, 1 - curV, 0)
					HueCursor.Position = UDim2.new(curH, 0, 0.5, 0)
					if callback then callback(curColor, 1) end
				end

				local draggingSV, draggingHue = false, false

				SvHit.MouseButton1Down:Connect(function() draggingSV = true end)
				HueHit.MouseButton1Down:Connect(function() draggingHue = true end)

				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						draggingSV = false; draggingHue = false
					end
				end)

				UserInputService.InputChanged:Connect(function(input)
					if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
					if not pickerOpen then return end
					if draggingSV then
						local ap = SvFrame.AbsolutePosition
						local as = SvFrame.AbsoluteSize
						curS = math.clamp((input.Position.X - ap.X) / as.X, 0, 1)
						curV = 1 - math.clamp((input.Position.Y - ap.Y) / as.Y, 0, 1)
						rebuildColor()
					elseif draggingHue then
						local ap = HueTrack.AbsolutePosition
						local as = HueTrack.AbsoluteSize
						curH = math.clamp((input.Position.X - ap.X) / as.X, 0, 1)
						rebuildColor()
					end
				end)

				local _origTrans = {}
				for _, obj in ipairs(Panel:GetDescendants()) do
					if obj:IsA("Frame") or obj:IsA("TextButton") then
						_origTrans[obj] = obj.BackgroundTransparency
					end
				end
				_origTrans[Panel] = Panel.BackgroundTransparency

				local function openPicker()
					pickerOpen = true
					updatePanelPos()
					Panel.BackgroundTransparency = 1
					Panel.Size = UDim2.new(0, 220, 0, PICKER_H * 0.94)
					for obj, _ in pairs(_origTrans) do
						if obj ~= Panel then obj.BackgroundTransparency = 1 end
					end
					Panel.Visible = true
					local ti = TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
					TweenService:Create(Panel, ti, {BackgroundTransparency = _origTrans[Panel], Size = UDim2.new(0, 220, 0, PICKER_H)}):Play()
					for obj, orig in pairs(_origTrans) do
						if obj ~= Panel then
							TweenService:Create(obj, ti, {BackgroundTransparency = orig}):Play()
						end
					end
					panelConn = RunService.RenderStepped:Connect(updatePanelPos)
				end

				local function closePicker()
					pickerOpen = false
					if panelConn then panelConn:Disconnect(); panelConn = nil end
					local ti = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
					TweenService:Create(Panel, ti, {BackgroundTransparency = 1, Size = UDim2.new(0, 220, 0, PICKER_H * 0.94)}):Play()
					for obj, _ in pairs(_origTrans) do
						if obj ~= Panel then
							TweenService:Create(obj, ti, {BackgroundTransparency = 1}):Play()
						end
					end
					task.delay(0.25, function()
						if not pickerOpen then
							Panel.Visible = false
							Panel.Size = UDim2.new(0, 220, 0, PICKER_H)
						end
					end)
				end
				_globalClosers[_cp_2] = closePicker

				Swatch.MouseButton1Click:Connect(function()
					local _wasOpen = pickerOpen
					_closeAll()
					if _wasOpen then closePicker() else openPicker() end
				end)

				UserInputService.InputBegan:Connect(function(input, gp)
					if gp then return end
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						if not pickerOpen then return end
						local mx, my = input.Position.X, input.Position.Y
						local pp = Panel.AbsolutePosition
						local ps = Panel.AbsoluteSize
						local sp = Swatch.AbsolutePosition
						local ss = Swatch.AbsoluteSize
						local insidePanel = mx >= pp.X and mx <= pp.X+ps.X and my >= pp.Y and my <= pp.Y+ps.Y
						local insideSwatch = mx >= sp.X and mx <= sp.X+ss.X and my >= sp.Y and my <= sp.Y+ss.Y
						if not insidePanel and not insideSwatch then closePicker() end
					end
				end)

				local ctrl = {}
				function ctrl:Set(color)
					curColor = color or curColor
					curH, curS, curV = color3ToHsv(curColor)
					rebuildColor()
				end
				function ctrl:Get() return curColor end
				return ctrl
			end

			------------------------------------------------------------
			-- Tab:AddKeybind
			-- A standalone keybind row with no toggle attached.
			--
			-- Table signature:
			--   Text, Desc, Default, Callback, ChangedCallback, SubTab
			--
			-- Callback(key)         → fires every time the bound key is pressed
			-- ChangedCallback(key)  → fires when the user rebinds via the chip
			--
			-- Usage:
			--   Tab:AddKeybind({
			--       Text            = "UI Toggle Key",
			--       Desc            = "Press chip to rebind",
			--       Default         = Enum.KeyCode.RightShift,
			--       SubTab          = "General",
			--       Callback        = function(key) print("pressed", key) end,
			--       ChangedCallback = function(key) Window:SetToggleKey(key) end,
			--   })
			------------------------------------------------------------
			function Tab:AddKeybind(label, description, default, callback, subTab)
				local changedCb = nil

				if type(label) == "table" then
					local t = label
					changedCb   = t.ChangedCallback or t.changedCallback
					label       = t.Text or t.Label or ""
					description = t.Desc or t.Description or ""
					default     = t.Default
					callback    = t.Callback
					subTab      = t.SubTab
				end

				local frame = getFrame(subTab)
				if not frame then return end

				local boundKey = default or nil
				local listeningForKey = false
				local keyConn = nil

				local _, Row = makeRowClip(frame, ROW_H)
				Row.BackgroundColor3 = C.ITEM
				MakeCorner(Row, 4)

				PlaceLabelDesc(Row, label, description, -110)

				-- keybind chip
				local KeyChip = Instance.new("TextButton")
				KeyChip.BackgroundColor3 = C.KEYBIND_BG
				KeyChip.BorderSizePixel  = 0
				KeyChip.Size             = UDim2.new(0, 46, 0, 26)
				KeyChip.Position         = UDim2.new(1, -60, 0.5, -13)
				KeyChip.Font             = Enum.Font.GothamBold
				KeyChip.Text             = boundKey and KeyName(boundKey) or "None"
				KeyChip.TextColor3       = boundKey and C.KEYBIND_ACT or C.TEXT3
				KeyChip.TextSize         = 10
				KeyChip.ZIndex           = 5
				KeyChip.Parent           = Row
				MakeCorner(KeyChip, 3)

				local function applyKey(kc)
					boundKey = kc
					if changedCb then changedCb(kc) end
					if kc then
						KeyChip.Text = KeyName(kc)
						Tween(KeyChip, {TextColor3 = C.KEYBIND_ACT, BackgroundColor3 = C.KEYBIND_BG}, 0.1)
					else
						KeyChip.Text = "None"
						Tween(KeyChip, {TextColor3 = C.TEXT3, BackgroundColor3 = C.KEYBIND_BG}, 0.1)
					end
					if keyConn then keyConn:Disconnect(); keyConn = nil end
					if kc then
						keyConn = UserInputService.InputBegan:Connect(function(input, gp)
							if not gp and input.KeyCode == kc then
								if callback then callback(kc) end
							end
						end)
					end
				end

				-- init without firing changedCb
				if boundKey then
					local _saved = changedCb
					changedCb = nil
					applyKey(boundKey)
					changedCb = _saved
				end

				KeyChip.MouseButton1Click:Connect(function()
					if listeningForKey then return end
					listeningForKey = true
					KeyChip.Text = "..."
					Tween(KeyChip, {TextColor3 = C.TEXT1, BackgroundColor3 = C.KEYBIND_BG}, 0.1)
					if keyConn then keyConn:Disconnect(); keyConn = nil end
					local listenConn
					listenConn = UserInputService.InputBegan:Connect(function(input, gp)
						if gp then return end
						listeningForKey = false
						listenConn:Disconnect()
						if input.KeyCode == Enum.KeyCode.Escape then
							applyKey(nil)
						elseif input.UserInputType == Enum.UserInputType.Keyboard then
							applyKey(input.KeyCode)
						end
					end)
				end)

				local ctrl = {}
				function ctrl:Set(kc)
					local _saved = changedCb
					changedCb = nil
					applyKey(kc)
					changedCb = _saved
				end
				function ctrl:Get() return boundKey end
				function ctrl:SetChangedCallback(fn) changedCb = fn end
				return ctrl
			end

			------------------------------------------------------------
			-- Tab:AddLabel
			------------------------------------------------------------
			function Tab:AddLabel(text, subTab)
				local frame = getFrame(subTab)
				if not frame then return end

				local _, Row = makeRowClip(frame, 32)
				Row.BackgroundColor3 = C.ITEM
				MakeCorner(Row, 4)

				local LabelTxt = Instance.new("TextLabel")
				LabelTxt.BackgroundTransparency = 1
				LabelTxt.Size = UDim2.new(1, -16, 1, 0)
				LabelTxt.Position = UDim2.new(0, 16, 0, 0)
				LabelTxt.Font = Enum.Font.GothamBold
				LabelTxt.Text = text
				LabelTxt.TextColor3 = C.TEXT2
				LabelTxt.TextSize = 11
				LabelTxt.TextXAlignment = Enum.TextXAlignment.Left
				LabelTxt.ZIndex = 4
				LabelTxt.Parent = Row

				local ctrl = {}
				function ctrl:Set(v) LabelTxt.Text = v end
				function ctrl:Get() return LabelTxt.Text end
				return ctrl
			end

			------------------------------------------------------------
			-- Tab:AddSeparator
			------------------------------------------------------------
			function Tab:AddSeparator(subTab)
				local frame = getFrame(subTab)
				if not frame then return end
				local _, Sep = makeRowClip(frame, 1)
				Sep.BackgroundColor3 = C.DIVIDER
			end

			table.insert(Window._tabs, Tab)
			return Tab
		end -- end Category:AddTab

		return Category
	end -- end Window:AddCategory

	task.defer(function()
		if Window._defaultTab and Window._defaultTab._activate then
			Window._defaultTab._activate()
		end
	end)

	return Window
end -- end NeronLib:CreateWindow

return NeronLib
