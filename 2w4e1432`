local function FormatValue(value, rounding)
	if rounding == nil or rounding == 0 then
		return tostring(math.floor(value + 0.5))
	end
	local stepStr = tostring(rounding)
	local dotPos = stepStr:find("%.")
	if not dotPos then
		return tostring(math.floor(value / rounding + 0.5) * rounding)
	end
	local decimals = #stepStr - dotPos
	local rounded = math.floor(value / rounding + 0.5) * rounding
	return string.format("%." .. decimals .. "f", rounded)
end

local function RoundValue(value, min, max, rounding)
	value = value ~= nil and value or 0
	min   = min   ~= nil and min   or 0
	max   = max   ~= nil and max   or 0
	if rounding == nil or rounding == 0 then
		return math.floor(math.clamp(value, min, max) + 0.5)
	end
	local snapped = math.floor(value / rounding + 0.5) * rounding
	return math.clamp(snapped, min, max)
end

-- ─── HSV ↔ Color3 helpers ────────────────────────────────────────────────────
local function hsvToColor3(h, s, v)
	local r, g, b
	local i = math.floor(h * 6)
	local f = h * 6 - i
	local p = v * (1 - s)
	local q = v * (1 - f * s)
	local t = v * (1 - (1 - f) * s)
	i = i % 6
	if     i == 0 then r,g,b = v,t,p
	elseif i == 1 then r,g,b = q,v,p
	elseif i == 2 then r,g,b = p,v,t
	elseif i == 3 then r,g,b = p,q,v
	elseif i == 4 then r,g,b = t,p,v
	elseif i == 5 then r,g,b = v,p,q
	end
	return Color3.new(r, g, b)
end

local function color3ToHsv(c)
	local r, g, b = c.R, c.G, c.B
	local max = math.max(r, g, b)
	local min = math.min(r, g, b)
	local d   = max - min
	local h, s, v
	v = max
	s = max == 0 and 0 or d / max
	if d == 0 then
		h = 0
	elseif max == r then
		h = ((g - b) / d) % 6
		h = h / 6
	elseif max == g then
		h = ((b - r) / d + 2) / 6
	else
		h = ((r - g) / d + 4) / 6
	end
	return h, s, v
end

