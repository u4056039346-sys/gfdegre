	local function hideAllTabContent()
		for _, tab in ipairs(Window._tabs) do
			for _, stName in ipairs(tab._subTabs and tab._subTabList or SUB_TABS) do
				local st = tab._subTabs[stName]
				if st and st.frame.Visible then
					st.frame.Visible = false
					if st.pad then st.pad.PaddingTop = UDim.new(0, 0) end
				end
			end
			tab._activeST = nil
			tab._activeSTBtn = nil
		end
	end

