			------------------------------------------------------------
			-- Tab:AddSlider
			------------------------------------------------------------
			function Tab:AddSlider(label, description, min, max, default, callback, subTab)
				local rounding = nil
				if type(label) == "table" then
					local t = label
					subTab      = description
					label       = t.Text or t.Label or ""
					min         = t.Min ~= nil and t.Min or 0
					max         = t.Max ~= nil and t.Max or 100
					default     = t.Default ~= nil and t.Default or min
					rounding    = t.Rounding
					callback    = t.Callback
					description = t.Desc or t.Description or nil
				elseif type(description) == "number" then
					subTab      = callback
					callback    = default
					default     = max
					max         = min
					min         = description
					description = nil
				end

				local frame = getFrame(subTab)
				if not frame then return end

				local value = RoundValue(default or min, min, max, rounding)
				local _, Row = makeRowClip(frame, ROW_H)
				Row.BackgroundColor3 = C.ITEM
				MakeCorner(Row, 4)

				local LabelTxt = PlaceLabelDesc(Row, label, description, -240)
				LabelTxt.TextColor3 = C.LABEL_OFF

				local ValueTxt = Instance.new("TextLabel")
				ValueTxt.BackgroundTransparency = 1
				ValueTxt.Size = UDim2.new(0, 150, 0, 6)
				ValueTxt.Position = UDim2.new(0.45, 0, 0.5, -3)
				ValueTxt.TextYAlignment = Enum.TextYAlignment.Center
				ValueTxt.Font = Enum.Font.GothamBold
				ValueTxt.Text = FormatValue(value, rounding)
				ValueTxt.TextColor3 = C.ACCENT_DIM
				ValueTxt.TextSize = 12
				ValueTxt.TextXAlignment = Enum.TextXAlignment.Right
				ValueTxt.ZIndex = 4
				ValueTxt.Parent = Row

				local TrackBG = Instance.new("Frame")
				TrackBG.BackgroundColor3 = Color3.fromRGB(20, 19, 24)
				TrackBG.BorderSizePixel = 0
				TrackBG.Size = UDim2.new(1, -400, 0, 10)
				TrackBG.Position = UDim2.new(0.65, 62, 0.5, -5)
				TrackBG.ZIndex = 4
				TrackBG.Parent = Row
				MakeCorner(TrackBG, 5)

				local initPct = (max ~= min) and ((value - min) / (max - min)) or 0

				local Fill = Instance.new("Frame")
				Fill.BackgroundColor3 = C.ACCENT
				Fill.BorderSizePixel = 0
				Fill.Size = UDim2.new(initPct, 0, 1, 0)
				Fill.ZIndex = 5
				Fill.Parent = TrackBG
				MakeCorner(Fill, 5)

				local SliderKnob = Instance.new("Frame")
				SliderKnob.BackgroundColor3 = Color3.fromRGB(11, 16, 31)
				SliderKnob.BorderSizePixel = 0
				SliderKnob.Size = UDim2.new(0, 4, 0, 4)
				SliderKnob.Position = UDim2.new(initPct, -6, 0.5, -2)
				SliderKnob.ZIndex = 6
				SliderKnob.Parent = TrackBG
				MakeCorner(SliderKnob, 6)

				local HitArea = Instance.new("TextButton")
				HitArea.BackgroundTransparency = 1
				HitArea.BorderSizePixel = 0
				HitArea.Size = UDim2.new(0, 20, 0, 20)
				HitArea.AnchorPoint = Vector2.new(0.5, 0.5)
				HitArea.Position = UDim2.new(initPct, -6, 0.5, -2)
				HitArea.Text = ""
				HitArea.ZIndex = 7
				HitArea.Parent = TrackBG

				local draggingSlider = false
				HitArea.MouseButton1Down:Connect(function()
					draggingSlider = true
					Tween(LabelTxt, {TextColor3 = C.LABEL_ON}, 0.15)
				end)
				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 and draggingSlider then
						draggingSlider = false
						Tween(LabelTxt, {TextColor3 = C.LABEL_OFF}, 0.25)
					end
				end)
				UserInputService.InputChanged:Connect(function(input)
					if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
						local absPos  = TrackBG.AbsolutePosition.X
						local absSize = TrackBG.AbsoluteSize.X
						local rawPct  = math.clamp((input.Position.X - absPos) / absSize, 0, 1)
						local rawVal  = min + (max - min) * rawPct
						value = RoundValue(rawVal, min, max, rounding)
						local pct = (max ~= min) and ((value - min) / (max - min)) or 0
						ValueTxt.Text = FormatValue(value, rounding)
						Fill.Size = UDim2.new(pct, 0, 1, 0)
						SliderKnob.Position = UDim2.new(pct, -6, 0.5, -2)
						HitArea.Position = UDim2.new(pct, 0, 0.5, 0)
						if callback then callback(value) end
					end
				end)

				local ctrl = {}
				function ctrl:Set(v)
					value = RoundValue(v, min, max, rounding)
					local pct = (max ~= min) and ((value - min) / (max - min)) or 0
					ValueTxt.Text = FormatValue(value, rounding)
					Fill.Size = UDim2.new(pct, 0, 1, 0)
					SliderKnob.Position = UDim2.new(pct, -6, 0.5, -2)
					HitArea.Position = UDim2.new(pct, 0, 0.5, 0)
					if callback then callback(value) end
				end
				function ctrl:Get() return value end
				return ctrl
			end

			------------------------------------------------------------
			-- Tab:AddRangeSlider
			------------------------------------------------------------
			function Tab:AddRangeSlider(label, options, callback, subTab)
				if type(label) == "table" then
					local t = label
					options  = t.Options or {}
					callback = t.Callback or t.callback
					subTab   = t.SubTab or t.subTab
					label    = t.Text or t.Label or ""
				end
				options = options or {}
				local min         = options.Min     or 0
				local max         = options.Max     or 100
				local defLow      = options.Default and options.Default[1] or min
				local defHigh     = options.Default and options.Default[2] or max
				local rounding    = options.Rounding or nil
				local description = options.Desc or options.Description or nil

				local frame = getFrame(subTab)
				if not frame then return end

				local valLow  = RoundValue(defLow,  min, max, rounding)
				local valHigh = RoundValue(defHigh, min, max, rounding)

				local _, Row = makeRowClip(frame, ROW_H)
				Row.BackgroundColor3 = C.ITEM
				MakeCorner(Row, 4)

				local LabelTxt = PlaceLabelDesc(Row, label, description, -240)
				LabelTxt.TextColor3 = C.LABEL_OFF

				local ValueTxt = Instance.new("TextLabel")
				ValueTxt.BackgroundTransparency = 1
				ValueTxt.Size = UDim2.new(0, 80, 0, 6)
				ValueTxt.Position = UDim2.new(0.45, 70, 0.5, -3)
				ValueTxt.TextYAlignment = Enum.TextYAlignment.Center
				ValueTxt.Font = Enum.Font.GothamBold
				ValueTxt.Text = FormatValue(valLow, rounding) .. ", " .. FormatValue(valHigh, rounding)
				ValueTxt.TextColor3 = C.ACCENT_DIM
				ValueTxt.TextSize = 12
				ValueTxt.TextXAlignment = Enum.TextXAlignment.Right
				ValueTxt.ZIndex = 4
				ValueTxt.Parent = Row

				local TrackBG = Instance.new("Frame")
				TrackBG.BackgroundColor3 = Color3.fromRGB(20, 19, 24)
				TrackBG.BorderSizePixel = 0
				TrackBG.Size = UDim2.new(1, -400, 0, 10)
				TrackBG.Position = UDim2.new(0.65, 62, 0.5, -5)
				TrackBG.ZIndex = 4
				TrackBG.Parent = Row
				MakeCorner(TrackBG, 5)

				local Fill = Instance.new("Frame")
				Fill.BackgroundColor3 = C.ACCENT
				Fill.BorderSizePixel = 0
				Fill.ZIndex = 5
				Fill.Parent = TrackBG
				MakeCorner(Fill, 3)

				local KnobLow = Instance.new("Frame")
				KnobLow.BackgroundColor3 = Color3.fromRGB(11, 16, 31)
				KnobLow.BorderSizePixel = 0
				KnobLow.Size = UDim2.new(0, 4, 0, 4)
				KnobLow.ZIndex = 7
				KnobLow.Parent = TrackBG
				MakeCorner(KnobLow, 4)

				local KnobHigh = Instance.new("Frame")
				KnobHigh.BackgroundColor3 = Color3.fromRGB(11, 16, 31)
				KnobHigh.BorderSizePixel = 0
				KnobHigh.Size = UDim2.new(0, 4, 0, 4)
				KnobHigh.ZIndex = 7
				KnobHigh.Parent = TrackBG
				MakeCorner(KnobHigh, 4)

				local HitAreaLow = Instance.new("TextButton")
				HitAreaLow.BackgroundTransparency = 1
				HitAreaLow.BorderSizePixel = 0
				HitAreaLow.Size = UDim2.new(0, 20, 0, 20)
				HitAreaLow.AnchorPoint = Vector2.new(0.5, 0.5)
				HitAreaLow.Text = ""
				HitAreaLow.ZIndex = 8
				HitAreaLow.Parent = TrackBG

				local HitAreaHigh = Instance.new("TextButton")
				HitAreaHigh.BackgroundTransparency = 1
				HitAreaHigh.BorderSizePixel = 0
				HitAreaHigh.Size = UDim2.new(0, 20, 0, 20)
				HitAreaHigh.AnchorPoint = Vector2.new(0.5, 0.5)
				HitAreaHigh.Text = ""
				HitAreaHigh.ZIndex = 8
				HitAreaHigh.Parent = TrackBG

				local function updateVisuals()
					local pctLow  = (max ~= min) and ((valLow  - min) / (max - min)) or 0
					local pctHigh = (max ~= min) and ((valHigh - min) / (max - min)) or 0
					Fill.Size          = UDim2.new(pctHigh - pctLow, 0, 1, 0)
					Fill.Position      = UDim2.new(pctLow, 0, 0, 0)
					KnobLow.Position   = UDim2.new(pctLow,  4, 0.5, -2)
					KnobHigh.Position  = UDim2.new(pctHigh, -6, 0.5, -2)
					HitAreaLow.Position  = UDim2.new(pctLow,  4, 0.5, -2)
					HitAreaHigh.Position = UDim2.new(pctHigh, -6, 0.5, -2)
					ValueTxt.Text = FormatValue(valLow, rounding) .. ", " .. FormatValue(valHigh, rounding)
				end
				updateVisuals()

				local draggingLow, draggingHigh = false, false
				HitAreaLow.MouseButton1Down:Connect(function() draggingLow = true; Tween(LabelTxt, {TextColor3 = C.LABEL_ON}, 0.15) end)
				HitAreaHigh.MouseButton1Down:Connect(function() draggingHigh = true; Tween(LabelTxt, {TextColor3 = C.LABEL_ON}, 0.15) end)
				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						if draggingLow or draggingHigh then Tween(LabelTxt, {TextColor3 = C.LABEL_OFF}, 0.25) end
						draggingLow = false; draggingHigh = false
					end
				end)
				UserInputService.InputChanged:Connect(function(input)
					if not (draggingLow or draggingHigh) then return end
					if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
					local absPos  = TrackBG.AbsolutePosition.X
					local absSize = TrackBG.AbsoluteSize.X
					local rawPct  = math.clamp((input.Position.X - absPos) / absSize, 0, 1)
					local rawVal  = min + (max - min) * rawPct
					if draggingLow then
						valLow = RoundValue(math.min(rawVal, valHigh), min, max, rounding)
					elseif draggingHigh then
						valHigh = RoundValue(math.max(rawVal, valLow), min, max, rounding)
					end
					updateVisuals()
					if callback then callback(valLow, valHigh) end
				end)

				local ctrl = {}
				function ctrl:Set(low, high)
					valLow  = RoundValue(math.min(low, high), min, max, rounding)
					valHigh = RoundValue(math.max(low, high), min, max, rounding)
					updateVisuals()
					if callback then callback(valLow, valHigh) end
				end
				function ctrl:Get() return valLow, valHigh end
				return ctrl
			end

