function Tab:_selectSubTab(stName)
    _closeAll()
    local stData = Tab._subTabs[stName]
    if not stData or not stData.btn then return end

    if Tab._activeST and Tab._subTabs[Tab._activeST] then
        local prev = Tab._subTabs[Tab._activeST]
        for _, child in ipairs(prev.frame:GetChildren()) do
            if child.Name == "RowClip" then
                local inner = child:FindFirstChild("RowInner")
                if inner then
                    TweenService:Create(inner,
                        TweenInfo.new(0.50, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                        {BackgroundTransparency = 1}
                    ):Play()
                end
                for _, obj in ipairs(child:GetDescendants()) do
                    if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                        TweenService:Create(obj,
                            TweenInfo.new(0.50, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                            {TextTransparency = 1}
                        ):Play()
                    elseif obj:IsA("Frame") then
                        TweenService:Create(obj,
                            TweenInfo.new(0.50, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                            {BackgroundTransparency = 1}
                        ):Play()
                    end
                end
            end
        end
        task.delay(0.51, function()
            if Tab._activeST ~= stName then return end
            prev.frame.Visible = false
            if prev.pad then prev.pad.PaddingTop = UDim.new(0, 0) end
            prev.underline.Visible = false
        end)
    end

    if Tab._activeSTBtn then
        Tween(Tab._activeSTBtn, {TextColor3 = C.TEXT2}, 0.1)
    end

    Tab._activeST = stName
    Tab._activeSTBtn = stData.btn
    Tween(stData.btn, {TextColor3 = C.TEXT1}, 0.1)
    stData.underline.Visible = true

    task.delay(0.51, function()
        if Tab._activeST ~= stName then return end
        stData.frame.Visible = true
        Content.CanvasPosition = Vector2.new(0, 0)
        Content.Position = UDim2.new(0, 0, 0, 0)
        slideRowsIn(stData.frame)
    end)
end

