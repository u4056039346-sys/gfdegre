			------------------------------------------------------------
			-- Tab:AddToggle
			--
			-- Table signature supports:
			--   Text, Desc, Default, Callback, SubTab, Keybind,
			--   Color, ColorCallback, KeybindCallback
			--
			-- Callback(state)         → fires when the toggle is clicked
			-- KeybindCallback(state)  → fires when the keybind is pressed,
			--                           receives current toggle state as context,
			--                           does NOT flip the toggle UI
			--
			-- If KeybindCallback is nil the keybind falls back to toggling
			-- the state (old behaviour).
			------------------------------------------------------------
			function Tab:AddToggle(label, description, default, callback, subTab, keybindKey)
				local showKeybind    = false
				local colorDefault   = nil
				local colorCb        = nil
				local keybindCb      = nil
				local changedCb      = nil

				if type(label) == "table" then
					local t = label
					showKeybind  = t.Keybind ~= nil
					colorDefault = t.Color
					colorCb      = t.ColorCallback
					keybindCb    = t.KeybindCallback or t.keybindCallback
					changedCb    = t.ChangedCallback or t.changedCallback
					label        = t.Text or t.Label or ""
					description  = t.Desc or t.Description or ""
					default      = t.Default or false
					callback     = t.Callback
					subTab       = t.SubTab
					keybindKey   = t.Keybind
				else
					showKeybind = keybindKey ~= nil
				end

				local showColor = colorDefault ~= nil

				local frame = getFrame(subTab)
				if not frame then return end

				local isOn = default or false
				local boundKey = keybindKey or nil
				local listeningForKey = false

				local _, Row = makeRowClip(frame, ROW_H)
				Row.BackgroundColor3 = C.ITEM
				MakeCorner(Row, 4)

				local rightOffset
				if showColor and showKeybind then
					rightOffset = -148
				elseif showColor then
					rightOffset = -98
				elseif showKeybind then
					rightOffset = -110
				else
					rightOffset = -60
				end

				local LabelTxt = PlaceLabelDesc(Row, label, description, rightOffset)
				LabelTxt.TextColor3 = isOn and C.LABEL_ON or C.LABEL_OFF

				-- ── optional inline color swatch ─────────────────────────────
				local inlineSwatch, colorPanelCtrl
				if showColor then
					local swatchRightX = showKeybind and -114 or -64
					inlineSwatch = Instance.new("TextButton")
					inlineSwatch.BackgroundColor3 = colorDefault
					inlineSwatch.BorderSizePixel  = 0
					inlineSwatch.Size             = UDim2.new(0, 26, 0, 26)
					inlineSwatch.Position         = UDim2.new(1, swatchRightX - 26 - 6, 0.5, -13)
					inlineSwatch.Text             = ""
					inlineSwatch.ZIndex           = 5
					inlineSwatch.Parent           = Row
					MakeCorner(inlineSwatch, 4)

					local curColor = colorDefault
					local curH, curS, curV = color3ToHsv(curColor)
					local pickerOpen = false
					local panelConn  = nil
					local _cp_1 = tostring({})

					local SV_W, SV_H = 200, 120
