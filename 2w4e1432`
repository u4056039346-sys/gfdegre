					end
					_globalClosers[_cp_1] = closePicker

					inlineSwatch.MouseButton1Click:Connect(function()
						local _wasOpen = pickerOpen
						_closeAll()
						if _wasOpen then closePicker() else openPicker() end
					end)

					UserInputService.InputBegan:Connect(function(input, gp)
						if gp then return end
						if input.UserInputType == Enum.UserInputType.MouseButton1 then
							if not pickerOpen then return end
							local mx, my = input.Position.X, input.Position.Y
							local pp = Panel.AbsolutePosition
							local ps = Panel.AbsoluteSize
							local sp = inlineSwatch.AbsolutePosition
							local ss = inlineSwatch.AbsoluteSize
							local insidePanel  = mx>=pp.X and mx<=pp.X+ps.X and my>=pp.Y and my<=pp.Y+ps.Y
							local insideSwatch = mx>=sp.X and mx<=sp.X+ss.X and my>=sp.Y and my<=sp.Y+ss.Y
							if not insidePanel and not insideSwatch then closePicker() end
						end
					end)

					colorPanelCtrl = {
						_getColor = function() return curColor, 1 end,
						_setColor = function(c, a)
							curColor = c or curColor
							curH, curS, curV = color3ToHsv(curColor)
							rebuildColor()
						end,
					}
				end

				-- ── keybind chip ──────────────────────────────────────────────
				local KeyChip, KbHint, keyConn
				if showKeybind then
					KeyChip = Instance.new("TextButton")
					KeyChip.BackgroundColor3 = C.KEYBIND_BG
					KeyChip.BorderSizePixel  = 0
					KeyChip.Size             = UDim2.new(0, 46, 0, 26)
					KeyChip.Position         = UDim2.new(1, -104, 0.5, -13)
					KeyChip.Font             = Enum.Font.GothamBold
					KeyChip.Text             = boundKey and KeyName(boundKey) or "None"
					KeyChip.TextColor3       = boundKey and C.KEYBIND_ACT or C.TEXT3
					KeyChip.TextSize         = 10
					KeyChip.ZIndex           = 5
					KeyChip.Parent           = Row
					MakeCorner(KeyChip, 3)

					KbHint = Instance.new("TextLabel")
					KbHint.BackgroundTransparency = 1
					KbHint.Size             = UDim2.new(0, 46, 0, 10)
					KbHint.Position         = UDim2.new(1, -104, 0, 3)
					KbHint.Font             = Enum.Font.GothamBold
					KbHint.Text             = ""
					KbHint.TextColor3       = C.TEXT3
					KbHint.TextSize         = 7
					KbHint.TextXAlignment   = Enum.TextXAlignment.Center
					KbHint.ZIndex           = 5
					KbHint.Visible          = false
					KbHint.Parent           = Row
				end

				-- ── toggle switch ─────────────────────────────────────────────
				local ToggleBG = Instance.new("Frame")
				ToggleBG.BackgroundColor3 = C.TOG_BG
				ToggleBG.BorderSizePixel  = 0
				ToggleBG.Size             = UDim2.new(0, 38, 0, 20)
				ToggleBG.Position         = UDim2.new(1, -54, 0.5, -10)
				ToggleBG.ZIndex           = 4
				ToggleBG.Parent           = Row
				MakeCorner(ToggleBG, 10)

				local Knob = Instance.new("TextButton")
				Knob.BackgroundColor3 = isOn and C.TOG_ON or C.TOG_OFF
				Knob.BorderSizePixel  = 0
				Knob.Size             = UDim2.new(0, 16, 0, 16)
				Knob.Position         = isOn and UDim2.new(0, 18, 0.5, -8) or UDim2.new(1, -34, 0.5, -8)
				Knob.Text             = ""
				Knob.ZIndex           = 5
				Knob.Parent           = ToggleBG
				MakeCorner(Knob, 8)

				local Dot = Instance.new("Frame")
				Dot.BackgroundColor3 = C.TOG_BG
				Dot.BorderSizePixel  = 0
				Dot.Size             = UDim2.new(0, 8, 0, 8)
				Dot.Position         = UDim2.new(0.5, -4, 0.5, -4)
				Dot.ZIndex           = 6
				Dot.Parent           = Knob
				MakeCorner(Dot, 4)

				local function updateToggle()
					if isOn then
						Tween(Knob, {Position = UDim2.new(0, 18, 0.5, -8), BackgroundColor3 = C.TOG_ON}, 0.2)
						Tween(LabelTxt, {TextColor3 = C.LABEL_ON}, 0.2)
					else
						Tween(Knob, {Position = UDim2.new(1, -34, 0.5, -8), BackgroundColor3 = C.TOG_OFF}, 0.2)
						Tween(LabelTxt, {TextColor3 = C.LABEL_OFF}, 0.2)
					end
				end

				-- clicking the toggle always flips state + calls Callback
				local function doToggle()
					isOn = not isOn
					updateToggle()
					if callback then callback(isOn) end
				end

				Knob.MouseButton1Click:Connect(doToggle)

				-- ── keybind logic ─────────────────────────────────────────────
				if showKeybind then
					--[[
						applyKey wires up the keyConn.
						Behaviour depends on whether KeybindCallback was supplied:

						  KeybindCallback present  → keybind fires KeybindCallback(currentState)
						                              WITHOUT touching the toggle UI.
						                              Use this when the keybind is a separate
						                              action that only works while the toggle is on
						                              (e.g. fly: toggle enables it, keybind starts/stops).

						  KeybindCallback absent   → keybind calls doToggle() just like clicking
						                              the toggle would (old / default behaviour).
					--]]
					local function applyKey(kc)
						boundKey = kc
						if changedCb then changedCb(kc) end
						if kc then
							KeyChip.Text = KeyName(kc)
							Tween(KeyChip, {TextColor3 = C.KEYBIND_ACT, BackgroundColor3 = C.KEYBIND_BG}, 0.1)
						else
							KeyChip.Text = "None"
							Tween(KeyChip, {TextColor3 = C.TEXT3, BackgroundColor3 = C.KEYBIND_BG}, 0.1)
						end

						if keyConn then keyConn:Disconnect(); keyConn = nil end

						if kc then
							keyConn = UserInputService.InputBegan:Connect(function(input, gp)
								if not gp and input.KeyCode == kc then
									if keybindCb then
										-- separate action: pass current toggle state as context
										keybindCb(isOn)
									else
										-- default: act like clicking the toggle
										doToggle()
									end
								end
							end)
						end
					end

					-- init: wire up the starting key without firing ChangedCallback
					if boundKey then
						local _saved = changedCb
						changedCb = nil
						applyKey(boundKey)
						changedCb = _saved
					end

					KeyChip.MouseButton1Click:Connect(function()
						if listeningForKey then return end
						listeningForKey = true
						KeyChip.Text = "..."
						Tween(KeyChip, {TextColor3 = C.TEXT1, BackgroundColor3 = C.KEYBIND_BG}, 0.1)
						if keyConn then keyConn:Disconnect(); keyConn = nil end
						local listenConn
						listenConn = UserInputService.InputBegan:Connect(function(input, gp)
							if gp then return end
							listeningForKey = false
							listenConn:Disconnect()
							if input.KeyCode == Enum.KeyCode.Escape then
								applyKey(nil)
							elseif input.UserInputType == Enum.UserInputType.Keyboard then
								applyKey(input.KeyCode)
							end
						end)
					end)

					KeyChip.MouseEnter:Connect(function() if not listeningForKey then KbHint.Visible = true end end)
					KeyChip.MouseLeave:Connect(function() KbHint.Visible = false end)
				end

				-- ── control object ────────────────────────────────────────────
				local ctrl = {}

				function ctrl:Set(val)
					isOn = val
					updateToggle()
					if callback then callback(isOn) end
				end

				function ctrl:Get()
					return isOn
				end

				function ctrl:SetKeybind(kc)
					if showKeybind and KeyChip then
						boundKey = kc
						if kc then
							KeyChip.Text = KeyName(kc)
							Tween(KeyChip, {TextColor3 = C.KEYBIND_ACT, BackgroundColor3 = Color3.fromRGB(28, 28, 40)}, 0.1)
						else
							KeyChip.Text = "None"
							Tween(KeyChip, {TextColor3 = C.TEXT3, BackgroundColor3 = C.KEYBIND_BG}, 0.1)
						end
						if keyConn then keyConn:Disconnect(); keyConn = nil end
						if kc then
							keyConn = UserInputService.InputBegan:Connect(function(input, gp)
								if not gp and input.KeyCode == kc then
									if keybindCb then
										keybindCb(isOn)
									else
										doToggle()
									end
								end
							end)
						end
					end
				end

				function ctrl:GetKeybind()
					return boundKey
				end

				function ctrl:GetColor()
					if colorPanelCtrl then return colorPanelCtrl._getColor() end
				end

				function ctrl:SetColor(color)
					if colorPanelCtrl then colorPanelCtrl._setColor(color) end
				end

				return ctrl
			end

