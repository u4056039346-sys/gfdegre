        end
    end
end)

local function HideUI()
    local duration = 0.25
    Main.Visible = true
    local tweens = {}
    if Shadow then
        table.insert(tweens, TweenService:Create(Shadow, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {ImageTransparency = 1}))
    end
    for _, obj in ipairs(Main:GetDescendants()) do
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then
            table.insert(tweens, TweenService:Create(obj, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 1}))
        elseif obj:IsA("Frame") or obj:IsA("ScrollingFrame") then
            table.insert(tweens, TweenService:Create(obj, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 1}))
        elseif obj:IsA("ImageLabel") and obj ~= Shadow then
            table.insert(tweens, TweenService:Create(obj, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {ImageTransparency = 1}))
        end
    end
    local mainTween = TweenService:Create(Main, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 1})
    mainTween:Play()
    for _, tw in ipairs(tweens) do tw:Play() end
    mainTween.Completed:Connect(function() Main.Visible = false end)
end

local function ShowUI()
    -- Reset all to fully transparent first so the fade-in is visible
    Main.BackgroundTransparency = 1
    for _, obj in ipairs(Main:GetDescendants()) do
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then
            obj.TextTransparency = 1
        elseif obj:IsA("Frame") or obj:IsA("ScrollingFrame") then
            obj.BackgroundTransparency = 1
        elseif obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
            obj.ImageTransparency = 1
        end
    end
    Main.Visible = true

    local duration = 0.25
    local tweens = {}
    if Shadow then
        table.insert(tweens, TweenService:Create(Shadow, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {ImageTransparency = _origTransparencies[Shadow] or 0}))
    end
    for _, obj in ipairs(Main:GetDescendants()) do
        local orig = _origTransparencies[obj]
        if orig == nil then continue end
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then
            table.insert(tweens, TweenService:Create(obj, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = orig}))
        elseif obj:IsA("Frame") or obj:IsA("ScrollingFrame") then
            table.insert(tweens, TweenService:Create(obj, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = orig}))
        elseif obj:IsA("ImageLabel") and obj ~= Shadow then
            table.insert(tweens, TweenService:Create(obj, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {ImageTransparency = orig}))
        end
    end
    local mainTween = TweenService:Create(Main, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = _origTransparencies[Main] or 0})
    mainTween:Play()
    for _, tw in ipairs(tweens) do tw:Play() end
end

