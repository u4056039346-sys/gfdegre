	-- Slide rows in from the left one by one (staggered)
	-- Each row must be wrapped in a clip frame (see makeRowClip below)
	local function slideRowsIn(frame)
		local clips = {}
		for _, child in ipairs(frame:GetChildren()) do
			if child.Name == "RowClip" then
				table.insert(clips, child)
			end
		end
		-- All start at the same time, but each one has a longer duration
		-- so first is fastest, last is slowest
		for i, clip in ipairs(clips) do
			local inner = clip:FindFirstChild("RowInner")
			if not inner then continue end
			inner.Position = UDim2.new(0, -300, 0, 0)
			inner.BackgroundTransparency = 1
			local duration = 0.9 + (i - 1) * 0.1
			local ti = TweenInfo.new(duration, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
			TweenService:Create(inner, ti, {Position = UDim2.new(0, 0, 0, 0)}):Play()
			Tween(inner, {BackgroundTransparency = 0}, duration * 0.8)
		end
	end

	-- Creates a clip+inner wrapper. Returns the inner frame which is used like a normal row parent.
	-- clip goes into the sub-tab frame (layout), inner slides inside it.
	local function makeRowClip(parentFrame, height)
		local clip = Instance.new("Frame")
		clip.Name = "RowClip"
		clip.BackgroundTransparency = 1
		clip.BorderSizePixel = 0
		clip.Size = UDim2.new(1, 0, 0, height)
		clip.ClipsDescendants = true
		clip.ZIndex = 3
		clip.Parent = parentFrame

		local inner = Instance.new("Frame")
		inner.Name = "RowInner"
		inner.BackgroundColor3 = Color3.fromRGB(16,16,20) -- C.ITEM placeholder, overwritten by caller
		inner.BorderSizePixel = 0
		inner.Size = UDim2.new(1, 0, 1, 0)
		inner.Position = UDim2.new(0, 0, 0, 0)
		inner.ZIndex = 3
		inner.Parent = clip
		return clip, inner
	end

