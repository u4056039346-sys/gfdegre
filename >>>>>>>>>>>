	function Window:AddCategory(categoryName)
		local Category = {}

		local CatContainer = Instance.new("Frame")
		CatContainer.Name = "CatContainer_" .. categoryName
		CatContainer.BackgroundTransparency = 1
		CatContainer.BorderSizePixel = 0
		CatContainer.Size = UDim2.new(1, 0, 0, 0)
		CatContainer.AutomaticSize = Enum.AutomaticSize.Y
		CatContainer.LayoutOrder = #SideScroll:GetChildren() + 1
		CatContainer.ZIndex = 3
		CatContainer.Parent = SideScroll
		MakeList(CatContainer, 1)

		local CatLabel = Instance.new("TextLabel")
		CatLabel.Name = "CatLabel_" .. categoryName
		CatLabel.BackgroundTransparency = 1
		CatLabel.Size = UDim2.new(1, 0, 0, 22)
		CatLabel.LayoutOrder = 0
		CatLabel.Font = Enum.Font.GothamBold
		CatLabel.Text = categoryName
		CatLabel.TextColor3 = C.CAT_LABEL
		CatLabel.TextSize = 10
		CatLabel.TextXAlignment = Enum.TextXAlignment.Left
		CatLabel.ZIndex = 4
		CatLabel.Parent = CatContainer
		MakePadding(CatLabel, 8, 0, 6, 0)

		local tabCount = 0

		function Category:AddTab(name, icon, desc)
			tabCount = tabCount + 1

			local Tab = {}
			Tab._name = name
			Tab._desc = desc or ""
			Tab._subTabs = {}
			Tab._activeST = nil
			Tab._activeSTBtn = nil

			for _, stName in ipairs(SUB_TABS) do
				-- Inner frame: lives directly in Content, slides on X
				local F = Instance.new("Frame")
				F.Name = "STFrame_" .. name .. "_" .. stName
				F.BackgroundTransparency = 1
				F.BorderSizePixel = 0
				F.Size = UDim2.new(1, 0, 0, 0)
				F.AutomaticSize = Enum.AutomaticSize.Y
				F.Position = UDim2.new(0, 0, 0, 0)
				F.Visible = false
				F.ZIndex = 3
				F.Parent = Content
				MakeList(F, 8)
				local FPad = Instance.new("UIPadding")
				FPad.PaddingTop = UDim.new(0, 0)
				FPad.Parent = F
				Tab._subTabs[stName] = {frame = F, clip = nil, pad = FPad, btn = nil, underline = nil}
			end

			local SideBtn = Instance.new("TextButton")
			SideBtn.Name = "SideBtn_" .. name
			SideBtn.BackgroundColor3 = C.SIDE_ACTIVE
			SideBtn.BackgroundTransparency = 1
			SideBtn.BorderSizePixel = 0
			SideBtn.Size = UDim2.new(1, 0, 0, 32)
			SideBtn.Font = Enum.Font.Gotham
			SideBtn.Text = ""
			SideBtn.ZIndex = 4
			SideBtn.LayoutOrder = tabCount
			SideBtn.Parent = CatContainer
			MakeCorner(SideBtn, 6)
			Tab._sideBtn = SideBtn

			local IconLbl = Instance.new("TextLabel")
			IconLbl.Name = "IconLbl"
			IconLbl.BackgroundTransparency = 1
			IconLbl.Size = UDim2.new(0, 20, 1, 0)
			IconLbl.Position = UDim2.new(0, 10, 0, 0)
			IconLbl.Font = Enum.Font.Gotham
			IconLbl.Text = icon or "•"
			IconLbl.TextColor3 = C.TEXT3
			IconLbl.TextSize = 13
			IconLbl.ZIndex = 5
			IconLbl.Parent = SideBtn

			local NameLbl = Instance.new("TextLabel")
			NameLbl.Name = "NameLbl"
			NameLbl.BackgroundTransparency = 1
			NameLbl.Size = UDim2.new(1, -34, 1, 0)
			NameLbl.Position = UDim2.new(0, 32, 0, 0)
			NameLbl.Font = Enum.Font.GothamBold
			NameLbl.Text = name
			NameLbl.TextColor3 = C.TEXT2
			NameLbl.TextSize = 10
			NameLbl.TextXAlignment = Enum.TextXAlignment.Left
			NameLbl.ZIndex = 5
			NameLbl.Parent = SideBtn

			SideBtn.MouseEnter:Connect(function()
				if Window._activeSideBtn ~= SideBtn then
					Tween(NameLbl, {TextColor3 = C.TEXT1}, 0.12)
					Tween(IconLbl, {TextColor3 = C.TEXT2}, 0.12)
				end
			end)
			SideBtn.MouseLeave:Connect(function()
				if Window._activeSideBtn ~= SideBtn then
					Tween(NameLbl, {TextColor3 = C.TEXT2}, 0.12)
					Tween(IconLbl, {TextColor3 = C.TEXT3}, 0.12)
				end
			end)

			local function buildSubTabBtns()
				for _, child in ipairs(SubRow:GetChildren()) do
					if child:IsA("TextButton") then child:Destroy() end
				end
				for _, stName in ipairs(SUB_TABS) do
					local stData = Tab._subTabs[stName]
					local Btn = Instance.new("TextButton")
					Btn.BackgroundTransparency = 1
					Btn.BorderSizePixel = 0
					Btn.Size = UDim2.new(0, 0, 1, 0)
					Btn.AutomaticSize = Enum.AutomaticSize.X
					Btn.Font = Enum.Font.GothamBold
					Btn.Text = stName
					Btn.TextColor3 = C.TEXT2
					Btn.TextSize = 11
					Btn.ZIndex = 4
					Btn.Parent = SubRow
					MakePadding(Btn, 0, 0, 4, 4)

					local Underline = Instance.new("Frame")
					Underline.BackgroundColor3 = C.ACCENT
					Underline.BorderSizePixel = 0
					Underline.Size = UDim2.new(1, 20, 0, 2)
					Underline.Position = UDim2.new(0, -6, 1, 6)
					Underline.Visible = false
					Underline.ZIndex = 5
					Underline.Parent = Btn

					stData.btn = Btn
					stData.underline = Underline

					local capturedName = stName
					Btn.MouseButton1Click:Connect(function()
						Tab:_selectSubTab(capturedName)
					end)
				end
			end

			function Tab:_selectSubTab(stName)
				local stData = Tab._subTabs[stName]
				if not stData or not stData.btn then return end

				if Tab._activeSTBtn then
					Tween(Tab._activeSTBtn, {TextColor3 = C.TEXT2}, 0.1)
				end
				-- Hide the previously active sub-tab
				if Tab._activeST and Tab._subTabs[Tab._activeST] then
					local prev = Tab._subTabs[Tab._activeST]
					prev.underline.Visible = false
					prev.frame.Visible = false
					if prev.pad then
						prev.pad.PaddingTop = UDim.new(0, 0)
					end
				end

				Tab._activeST = stName
				Tab._activeSTBtn = stData.btn
				Tween(stData.btn, {TextColor3 = C.TEXT1}, 0.1)
				stData.underline.Visible = true

				stData.frame.Visible = true

				-- Reset scroll to top, keep Content pinned
				Content.CanvasPosition = Vector2.new(0, 0)
				Content.Position = UDim2.new(0, 0, 0, 0)

				-- Slide each row in from the left with stagger
				slideRowsIn(stData.frame)
			end

			local function onSideBtnClicked()
				if Window._activeSideBtn == SideBtn then return end

				local fadingFrames = {}
				for _, t in ipairs(Window._tabs) do
					for _, stName in ipairs(SUB_TABS) do
						local st = t._subTabs[stName]
						if st and st.frame.Visible then
							table.insert(fadingFrames, st.frame)
							for _, child in ipairs(st.frame:GetChildren()) do
								if child:IsA("Frame") or child:IsA("TextButton") then
									Tween(child, {BackgroundTransparency = 1}, 0.1)
								end
							end
						end
					end
				end

				deselectCurrentSideBtn()
				Window._activeSideBtn = SideBtn
				Window._activeSideBtnNameLbl = NameLbl
				Window._activeSideBtnIconLbl = IconLbl

				Tween(SideBtn, {
					BackgroundColor3 = C.SIDE_ACTIVE,
					BackgroundTransparency = 0
				}, 0.15)
				Tween(NameLbl, {TextColor3 = C.TEXT1}, 0.15)
				Tween(IconLbl, {TextColor3 = C.ACCENT_DIM}, 0.15)

				Tween(TopTitle, {TextTransparency = 1}, 0.08)
				Tween(TopDesc, {TextTransparency = 1}, 0.08)

				task.delay(0.12, function()
					for _, f in ipairs(fadingFrames) do
						f.Visible = false
					end
					hideAllTabContent()
					TopTitle.Text = name
					TopDesc.Text = Tab._desc
					Tween(TopTitle, {TextTransparency = 0}, 0.15)
					Tween(TopDesc, {TextTransparency = 0}, 0.15)
					buildSubTabBtns()
					Tab._activeST = nil
					Tab._activeSTBtn = nil
					Tab:_selectSubTab("General")
				end)
			end

			SideBtn.MouseButton1Click:Connect(onSideBtnClicked)
			Tab._sideBtn = SideBtn
			Tab._activate = onSideBtnClicked

			local function getFrame(subTab)
				local st = subTab or "General"
				local stData = Tab._subTabs[st]
				if stData then return stData.frame end
				return nil
			end

			------------------------------------------------------------
			-- Tab:AddToggle
			-- Sig A (table): { Text, Desc, Default, Callback, SubTab, Keybind }
			-- Sig B (args):  label, description, default, callback, subTab, keybindKey
			------------------------------------------------------------
			function Tab:AddToggle(label, description, default, callback, subTab, keybindKey)
				local showKeybind = false
				if type(label) == "table" then
					local t = label
					showKeybind = t.Keybind ~= nil
					label       = t.Text or t.Label or ""
					description = t.Desc or t.Description or ""
					default     = t.Default or false
					callback    = t.Callback
					subTab      = t.SubTab
					keybindKey  = t.Keybind
				else
					showKeybind = keybindKey ~= nil
				end

				local frame = getFrame(subTab)
				if not frame then return end

				local isOn = default or false
				local boundKey = keybindKey or nil
				local listeningForKey = false

				local _, Row = makeRowClip(frame, ROW_H)
				Row.BackgroundColor3 = C.ITEM
				MakeCorner(Row, 4)

				-- reserve space for keybind chip (46px) + gap + toggle (54px)
				local rightOffset = showKeybind and -110 or -60
				local LabelTxt = PlaceLabelDesc(Row, label, description, rightOffset)

				-- Set initial label color based on default state
				LabelTxt.TextColor3 = isOn and C.LABEL_ON or C.LABEL_OFF

				local KeyChip, KbHint, keyConn
				if showKeybind then
					KeyChip = Instance.new("TextButton")
					KeyChip.BackgroundColor3 = C.KEYBIND_BG
					KeyChip.BorderSizePixel = 0
					KeyChip.Size = UDim2.new(0, 46, 0, 18)
					KeyChip.Position = UDim2.new(1, -104, 0.5, -9)
					KeyChip.Font = Enum.Font.GothamBold
					KeyChip.Text = boundKey and KeyName(boundKey) or "None"
					KeyChip.TextColor3 = boundKey and C.KEYBIND_ACT or C.TEXT3
					KeyChip.TextSize = 9
					KeyChip.ZIndex = 5
					KeyChip.Parent = Row
					MakeCorner(KeyChip, 3)

					KbHint = Instance.new("TextLabel")
					KbHint.BackgroundTransparency = 1
					KbHint.Size = UDim2.new(0, 46, 0, 10)
					KbHint.Position = UDim2.new(1, -104, 0, 3)
					KbHint.Font = Enum.Font.GothamBold
					KbHint.Text = ""
					KbHint.TextColor3 = C.TEXT3
					KbHint.TextSize = 7
					KbHint.TextXAlignment = Enum.TextXAlignment.Center
					KbHint.ZIndex = 5
					KbHint.Visible = false
					KbHint.Parent = Row
				end

				local ToggleBG = Instance.new("Frame")
				ToggleBG.BackgroundColor3 = C.TOG_BG
				ToggleBG.BorderSizePixel = 0
				ToggleBG.Size = UDim2.new(0, 38, 0, 20)
				ToggleBG.Position = UDim2.new(1, -54, 0.5, -10)
				ToggleBG.ZIndex = 4
				ToggleBG.Parent = Row
				MakeCorner(ToggleBG, 10)

				local Knob = Instance.new("TextButton")
				Knob.BackgroundColor3 = isOn and C.TOG_ON or C.TOG_OFF
				Knob.BorderSizePixel = 0
				Knob.Size = UDim2.new(0, 16, 0, 16)
				Knob.Position = isOn and UDim2.new(0, 18, 0.5, -8) or UDim2.new(1, -34, 0.5, -8)
				Knob.Text = ""
				Knob.ZIndex = 5
				Knob.Parent = ToggleBG
				MakeCorner(Knob, 8)

				local Dot = Instance.new("Frame")
				Dot.BackgroundColor3 = C.TOG_BG
				Dot.BorderSizePixel = 0
				Dot.Size = UDim2.new(0, 8, 0, 8)
				Dot.Position = UDim2.new(0.5, -4, 0.5, -4)
				Dot.ZIndex = 6
				Dot.Parent = Knob
				MakeCorner(Dot, 4)

				local function updateToggle()
					if isOn then
						Tween(Knob, {Position = UDim2.new(0, 18, 0.5, -8), BackgroundColor3 = C.TOG_ON}, 0.2)
						-- Tween label text to ON color
						Tween(LabelTxt, {TextColor3 = C.LABEL_ON}, 0.2)
					else
						Tween(Knob, {Position = UDim2.new(1, -34, 0.5, -8), BackgroundColor3 = C.TOG_OFF}, 0.2)
						-- Tween label text to OFF color
						Tween(LabelTxt, {TextColor3 = C.LABEL_OFF}, 0.2)
					end
				end

				local function doToggle()
					isOn = not isOn
					updateToggle()
					if callback then callback(isOn) end
				end

				Knob.MouseButton1Click:Connect(doToggle)

				if showKeybind then
					local function applyKey(kc)
						boundKey = kc
						if kc then
							KeyChip.Text = KeyName(kc)
							Tween(KeyChip, {TextColor3 = C.KEYBIND_ACT, BackgroundColor3 = Color3.fromRGB(28, 28, 40)}, 0.1)
						else
							KeyChip.Text = "None"
							Tween(KeyChip, {TextColor3 = C.TEXT3, BackgroundColor3 = C.KEYBIND_BG}, 0.1)
						end
						if keyConn then keyConn:Disconnect(); keyConn = nil end
						if kc then
							keyConn = UserInputService.InputBegan:Connect(function(input, gp)
								if not gp and input.KeyCode == kc then doToggle() end
							end)
						end
					end

					if boundKey then applyKey(boundKey) end

					KeyChip.MouseButton1Click:Connect(function()
						if listeningForKey then return end
						listeningForKey = true
						KeyChip.Text = "..."
						Tween(KeyChip, {TextColor3 = C.TEXT1, BackgroundColor3 = Color3.fromRGB(35, 35, 55)}, 0.1)
						if keyConn then keyConn:Disconnect(); keyConn = nil end
						local listenConn
						listenConn = UserInputService.InputBegan:Connect(function(input, gp)
							if gp then return end
							listeningForKey = false
							listenConn:Disconnect()
							if input.KeyCode == Enum.KeyCode.Escape then
								applyKey(nil)
							elseif input.UserInputType == Enum.UserInputType.Keyboard then
								applyKey(input.KeyCode)
							end
						end)
					end)

					KeyChip.MouseEnter:Connect(function()
						if not listeningForKey then KbHint.Visible = true end
					end)
					KeyChip.MouseLeave:Connect(function()
						KbHint.Visible = false
					end)
				end

				local ctrl = {}
				function ctrl:Set(val)
					isOn = val
					updateToggle()
					if callback then callback(isOn) end
				end
				function ctrl:Get() return isOn end
				function ctrl:SetKeybind(kc)
					if showKeybind and KeyChip then
						boundKey = kc
						if kc then
							KeyChip.Text = KeyName(kc)
							Tween(KeyChip, {TextColor3 = C.KEYBIND_ACT, BackgroundColor3 = Color3.fromRGB(28, 28, 40)}, 0.1)
						else
							KeyChip.Text = "None"
							Tween(KeyChip, {TextColor3 = C.TEXT3, BackgroundColor3 = C.KEYBIND_BG}, 0.1)
						end
						if keyConn then keyConn:Disconnect(); keyConn = nil end
						if kc then
							keyConn = UserInputService.InputBegan:Connect(function(input, gp)
								if not gp and input.KeyCode == kc then doToggle() end
							end)
						end
					end
				end
				function ctrl:GetKeybind() return boundKey end
				return ctrl
			end

