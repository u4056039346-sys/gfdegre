					local parts = {}
					for _, opt in ipairs(options) do
						if selected[opt] then parts[#parts + 1] = opt end
					end
					if #parts == 0 then return "None"
					elseif #parts == 1 then return parts[1]
					else return #parts .. " selected" end
				end

				local function getSelectedList()
					local result = {}
					for _, opt in ipairs(options) do
						if selected[opt] then result[#result + 1] = opt end
					end
					return result
				end

