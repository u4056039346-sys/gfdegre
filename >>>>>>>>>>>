local ROW_H = 49

-- ┌─────────────────────────────────────────────────────────────────────────┐
-- │  PlaceLabelDesc — the ONE function used by every component              │
-- │  label      : string — bold white title text                            │
-- │  description: string or nil — small grey subtitle below the title       │
-- │  rightOffset: number — how many px to pull the label's right edge in    │
-- │               (leave room for the control on the right side)            │
-- │  Returns the LabelTxt instance in case the caller needs it.             │
-- └─────────────────────────────────────────────────────────────────────────┘
local function PlaceLabelDesc(parent, label, description, rightOffset)
	local hasDesc = description and description ~= ""
	-- With a description: title at y=6, desc at y=27
	-- Without:            title vertically centred in ROW_H
	local labelY = hasDesc and 6 or (ROW_H / 2 - 10)

	local LabelTxt = Instance.new("TextLabel")
	LabelTxt.BackgroundTransparency = 1
	LabelTxt.Size = UDim2.new(1, rightOffset, 0, 20)
	LabelTxt.Position = UDim2.new(0, 16, 0, labelY)
	LabelTxt.Font = Enum.Font.GothamBold
	LabelTxt.Text = label
	LabelTxt.TextColor3 = C.TEXT1
	LabelTxt.TextSize = 12
	LabelTxt.TextXAlignment = Enum.TextXAlignment.Left
	LabelTxt.ZIndex = 4
	LabelTxt.Parent = parent

	if hasDesc then
		local DescTxt = Instance.new("TextLabel")
		DescTxt.BackgroundTransparency = 1
		DescTxt.Size = UDim2.new(1, rightOffset, 0, 16)
		DescTxt.Position = UDim2.new(0, 16, 0, 27)
		DescTxt.Font = Enum.Font.Gotham
		DescTxt.Text = description
		DescTxt.TextColor3 = C.TEXT3
		DescTxt.TextSize = 10
		DescTxt.TextXAlignment = Enum.TextXAlignment.Left
		DescTxt.TextWrapped = true
		DescTxt.ZIndex = 4
		DescTxt.Parent = parent
	end

	return LabelTxt
end

