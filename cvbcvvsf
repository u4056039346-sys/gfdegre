				DropBtn.TextSize = 11
				DropBtn.TextXAlignment = Enum.TextXAlignment.Left
				DropBtn.ZIndex = 11
				DropBtn.Parent = Row
				MakeCorner(DropBtn, 4)
				MakePadding(DropBtn, 0, 0, 10, 28)

				local DropArrow = Instance.new("TextLabel")
				DropArrow.BackgroundTransparency = 1
				DropArrow.Size = UDim2.new(0, 64, 1, 0)
				DropArrow.Position = UDim2.new(1, -14, 0, 0)
				DropArrow.Font = Enum.Font.GothamBold
				DropArrow.Text = "^"
				DropArrow.TextColor3 = C.TEXT33
				DropArrow.TextSize = 13
				DropArrow.ZIndex = 12
				DropArrow.Parent = DropBtn

				local DropList = Instance.new("Frame")
				DropList.BackgroundColor3 = C.DROPDOWN_BG
				DropList.BorderSizePixel = 0
				DropList.Size = UDim2.new(0.5, -16, 0, #options * 28 + 8)
				DropList.Position = UDim2.new(0.5, 0, 0, ROW_H + 2)
				DropList.Visible = false
				DropList.ZIndex = 20
				DropList.Parent = Row
				MakeCorner(DropList, 4)
				MakePadding(DropList, 4, 4, 4, 4)
				MakeList(DropList, 2)

				for _, opt in ipairs(options) do
					local OptBtn = Instance.new("TextButton")
					OptBtn.BackgroundColor3 = C.DROPDOWN_BG
					OptBtn.BackgroundTransparency = 1
					OptBtn.BorderSizePixel = 0
					OptBtn.Size = UDim2.new(1, 0, 0, 24)
					OptBtn.Font = Enum.Font.Gotham
					OptBtn.Text = opt
					OptBtn.TextColor3 = opt == selected and C.TEXT1 or C.TEXT2
					OptBtn.TextSize = 11
					OptBtn.TextXAlignment = Enum.TextXAlignment.Left
					OptBtn.ZIndex = 21
					OptBtn.Parent = DropList
					MakePadding(OptBtn, 0, 0, 8, 8)
					MakeCorner(OptBtn, 3)

					local SelDot = Instance.new("Frame")
					SelDot.BackgroundColor3 = C.ACCENT
					SelDot.BorderSizePixel = 0
					SelDot.Size = UDim2.new(0, 6, 0, 6)
					SelDot.Position = UDim2.new(1, -14, 0.5, -3)
					SelDot.Visible = opt == selected
					SelDot.ZIndex = 22
					SelDot.Parent = OptBtn
					MakeCorner(SelDot, 3)

					OptBtn.MouseEnter:Connect(function() Tween(OptBtn, {BackgroundTransparency = 0.7}, 0.1) end)
					OptBtn.MouseLeave:Connect(function() Tween(OptBtn, {BackgroundTransparency = 1}, 0.1) end)
					OptBtn.MouseButton1Click:Connect(function()
						selected = opt
						DropBtn.Text = opt
						for _, o in ipairs(DropList:GetChildren()) do
							if o:IsA("TextButton") then
								o.TextColor3 = o.Text == selected and C.TEXT1 or C.TEXT2
								local dot = o:FindFirstChildWhichIsA("Frame")
								if dot then dot.Visible = o.Text == selected end
							end
						end
						open = false
						DropList.Visible = false
						Tween(DropArrow, {Rotation = 0}, 0.15)
						if callback then callback(selected) end
					end)
				end

				DropBtn.MouseButton1Click:Connect(function()
					open = not open
					DropList.Visible = open
					Tween(DropArrow, {Rotation = open and 180 or 0}, 0.15)
				end)

				local ctrl = {}
				function ctrl:Set(v) selected = v; DropBtn.Text = v; if callback then callback(selected) end end
				function ctrl:Get() return selected end
				return ctrl
			end

			------------------------------------------------------------
			-- Tab:AddMultiDropdown
			-- Sig A (table): { Text, Desc, Options, Default, Callback, SubTab }
			-- Sig B (full):  label, description, options, defaults, callback, subTab
			-- Sig C (short): label, options, defaults, callback, subTab  (no description)
			------------------------------------------------------------
			function Tab:AddMultiDropdown(label, description, options, defaults, callback, subTab)
				if type(label) == "table" then
					local t = label
					options     = t.Options   or t.options  or {}
					defaults    = t.Default   or t.defaults or {}
					callback    = t.Callback  or t.callback
					subTab      = t.SubTab    or t.subTab
					description = t.Desc      or t.Description or nil
					label       = t.Text      or t.Label    or ""
				elseif type(description) == "table" then
					-- old 5-arg: (label, options, defaults, callback, subTab)
					subTab      = callback
					callback    = defaults
					defaults    = options
					options     = description
					description = nil
				end
				if type(defaults) == "function" then
					subTab = callback; callback = defaults; defaults = {}
				end

				local frame = getFrame(subTab)
				if not frame then return end

				local selected = {}
				if defaults then for _, v in ipairs(defaults) do selected[v] = true end end

				local open = false

				local function getDisplayText()
					local parts = {}
					for _, opt in ipairs(options) do
						if selected[opt] then parts[#parts + 1] = opt end
					end
					if #parts == 0 then return "None"
					elseif #parts == 1 then return parts[1]
					else return #parts .. " selected" end
				end

				local function getSelectedList()
					local result = {}
					for _, opt in ipairs(options) do
						if selected[opt] then result[#result + 1] = opt end
					end
					return result
				end

				local Row = Instance.new("Frame")
				Row.BackgroundColor3 = C.ITEM
				Row.BorderSizePixel = 0
				Row.Size = UDim2.new(1, 0, 0, ROW_H)
				Row.ClipsDescendants = false
				Row.ZIndex = 10
				Row.Parent = frame
				MakeCorner(Row, 4)

				-- same rightOffset as Dropdown so they look identical
				PlaceLabelDesc(Row, label, description, -220)

				local DropBtn = Instance.new("TextButton")
				DropBtn.BackgroundColor3 = C.INPUT_BG
				DropBtn.BorderSizePixel = 0
				DropBtn.Size = UDim2.new(0.5, -135, 0, 28)
				DropBtn.Position = UDim2.new(0.5, 120, 0.5, -14)
				DropBtn.Font = Enum.Font.Gotham
				DropBtn.Text = getDisplayText()
				DropBtn.TextColor3 = C.TEXT2
				DropBtn.TextSize = 11
				DropBtn.TextXAlignment = Enum.TextXAlignment.Left
				DropBtn.ZIndex = 11
				DropBtn.Parent = Row
				MakeCorner(DropBtn, 4)
				MakePadding(DropBtn, 0, 0, 10, 28)

				local DropArrow = Instance.new("TextLabel")
				DropArrow.BackgroundTransparency = 1
				DropArrow.Size = UDim2.new(0, 64, 1, 0)
				DropArrow.Position = UDim2.new(1, -14, 0, 0)
				DropArrow.Font = Enum.Font.GothamBold
				DropArrow.Text = "^"
				DropArrow.TextColor3 = C.TEXT33
				DropArrow.TextSize = 13
				DropArrow.ZIndex = 12
				DropArrow.Parent = DropBtn

				local DropList = Instance.new("Frame")
				DropList.BackgroundColor3 = C.DROPDOWN_BG
				DropList.BorderSizePixel = 0
				DropList.Size = UDim2.new(0.5, -16, 0, #options * 28 + 8)
				DropList.Position = UDim2.new(0.5, 0, 0, ROW_H + 2)
				DropList.Visible = false
				DropList.ZIndex = 20
				DropList.Parent = Row
				MakeCorner(DropList, 4)
				MakePadding(DropList, 4, 4, 4, 4)
				MakeList(DropList, 2)

				local optButtons = {}
				local function refreshOption(optBtn, checkDot, opt)
					local isSelected = selected[opt] == true
					optBtn.TextColor3 = isSelected and C.TEXT1 or C.TEXT2
					checkDot.Visible = isSelected
				end

				for _, opt in ipairs(options) do
					local OptBtn = Instance.new("TextButton")
					OptBtn.BackgroundColor3 = C.DROPDOWN_BG
					OptBtn.BackgroundTransparency = 1
					OptBtn.BorderSizePixel = 0
					OptBtn.Size = UDim2.new(1, 0, 0, 24)
					OptBtn.Font = Enum.Font.Gotham
					OptBtn.Text = tostring(opt)
					OptBtn.TextColor3 = selected[opt] and C.TEXT1 or C.TEXT2
					OptBtn.TextSize = 11
					OptBtn.TextXAlignment = Enum.TextXAlignment.Left
					OptBtn.ZIndex = 21
					OptBtn.Parent = DropList
					MakePadding(OptBtn, 0, 0, 8, 8)
					MakeCorner(OptBtn, 3)

					local CheckDot = Instance.new("Frame")
					CheckDot.BackgroundColor3 = C.ACCENT
					CheckDot.BorderSizePixel = 0
					CheckDot.Size = UDim2.new(0, 6, 0, 6)
					CheckDot.Position = UDim2.new(1, -14, 0.5, -3)
					CheckDot.Visible = selected[opt] == true
					CheckDot.ZIndex = 22
					CheckDot.Parent = OptBtn
					MakeCorner(CheckDot, 3)

					optButtons[opt] = {btn = OptBtn, dot = CheckDot}

					OptBtn.MouseEnter:Connect(function() Tween(OptBtn, {BackgroundTransparency = 0.7}, 0.1) end)
					OptBtn.MouseLeave:Connect(function() Tween(OptBtn, {BackgroundTransparency = 1}, 0.1) end)
					OptBtn.MouseButton1Click:Connect(function()
						if selected[opt] then selected[opt] = nil else selected[opt] = true end
						refreshOption(OptBtn, CheckDot, opt)
						DropBtn.Text = getDisplayText()
						if callback then callback(getSelectedList()) end
					end)
				end

				DropBtn.MouseButton1Click:Connect(function()
					open = not open
					DropList.Visible = open
					Tween(DropArrow, {Rotation = open and 180 or 0}, 0.15)
				end)

				local ctrl = {}
				function ctrl:Set(tbl)
					selected = {}
					for _, v in ipairs(tbl) do selected[v] = true end
					DropBtn.Text = getDisplayText()
					for opt, pair in pairs(optButtons) do refreshOption(pair.btn, pair.dot, opt) end
					if callback then callback(getSelectedList()) end
				end
				function ctrl:Get() return getSelectedList() end
				return ctrl
			end

			------------------------------------------------------------
			-- Tab:AddLabel
			------------------------------------------------------------
			function Tab:AddLabel(text, subTab)
				local frame = getFrame(subTab)
				if not frame then return end

				local Row = Instance.new("Frame")
				Row.BackgroundColor3 = C.ITEM
				Row.BorderSizePixel = 0
				Row.Size = UDim2.new(1, 0, 0, 32)
				Row.ZIndex = 3
				Row.Parent = frame
				MakeCorner(Row, 4)

				local LabelTxt = Instance.new("TextLabel")
				LabelTxt.BackgroundTransparency = 1
				LabelTxt.Size = UDim2.new(1, -16, 1, 0)
				LabelTxt.Position = UDim2.new(0, 16, 0, 0)
				LabelTxt.Font = Enum.Font.Gotham
				LabelTxt.Text = text
				LabelTxt.TextColor3 = C.TEXT2
				LabelTxt.TextSize = 11
				LabelTxt.TextXAlignment = Enum.TextXAlignment.Left
				LabelTxt.ZIndex = 4
				LabelTxt.Parent = Row

				local ctrl = {}
				function ctrl:Set(v) LabelTxt.Text = v end
				function ctrl:Get() return LabelTxt.Text end
				return ctrl
			end

			------------------------------------------------------------
			-- Tab:AddSeparator
			------------------------------------------------------------
			function Tab:AddSeparator(subTab)
				local frame = getFrame(subTab)
				if not frame then return end

				local Sep = Instance.new("Frame")
				Sep.BackgroundColor3 = C.DIVIDER
				Sep.BorderSizePixel = 0
				Sep.Size = UDim2.new(1, 0, 0, 1)
				Sep.ZIndex = 3
				Sep.Parent = frame
			end

			table.insert(Window._tabs, Tab)
			return Tab
		end -- end Category:AddTab

		return Category
	end -- end Window:AddCategory

	task.defer(function()
		if Window._defaultTab and Window._defaultTab._activate then
			Window._defaultTab._activate()
		end
	end)

	return Window
end -- end NeronLib:CreateWindow

return NeronLib
