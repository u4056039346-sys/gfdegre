			------------------------------------------------------------
			-- Tab:AddToggle
			-- Sig A (table): { Text, Desc, Default, Callback, SubTab, Keybind }
			-- Sig B (args):  label, description, default, callback, subTab, keybindKey
			------------------------------------------------------------
			function Tab:AddToggle(label, description, default, callback, subTab, keybindKey)
				local showKeybind = false
				if type(label) == "table" then
					local t = label
					showKeybind = t.Keybind ~= nil
					label       = t.Text or t.Label or ""
					description = t.Desc or t.Description or ""
					default     = t.Default or false
					callback    = t.Callback
					subTab      = t.SubTab
					keybindKey  = t.Keybind
				else
					showKeybind = keybindKey ~= nil
				end

				local frame = getFrame(subTab)
				if not frame then return end

				local isOn = default or false
				local boundKey = keybindKey or nil
				local listeningForKey = false

				local Row = Instance.new("Frame")
				Row.BackgroundColor3 = C.ITEM
				Row.BorderSizePixel = 0
				Row.Size = UDim2.new(1, 0, 0, ROW_H)
				Row.ZIndex = 3
				Row.Parent = frame
				MakeCorner(Row, 4)

				-- reserve space for keybind chip (46px) + gap + toggle (54px)
				local rightOffset = showKeybind and -110 or -60
				PlaceLabelDesc(Row, label, description, rightOffset)

				local KeyChip, KbHint, keyConn
				if showKeybind then
					KeyChip = Instance.new("TextButton")
					KeyChip.BackgroundColor3 = C.KEYBIND_BG
					KeyChip.BorderSizePixel = 0
					KeyChip.Size = UDim2.new(0, 46, 0, 18)
					KeyChip.Position = UDim2.new(1, -104, 0.5, -9)
					KeyChip.Font = Enum.Font.GothamBold
					KeyChip.Text = boundKey and KeyName(boundKey) or "None"
					KeyChip.TextColor3 = boundKey and C.KEYBIND_ACT or C.TEXT3
					KeyChip.TextSize = 9
					KeyChip.ZIndex = 5
					KeyChip.Parent = Row
					MakeCorner(KeyChip, 3)

					KbHint = Instance.new("TextLabel")
					KbHint.BackgroundTransparency = 1
					KbHint.Size = UDim2.new(0, 46, 0, 10)
					KbHint.Position = UDim2.new(1, -104, 0, 3)
					KbHint.Font = Enum.Font.Gotham
					KbHint.Text = "BIND"
					KbHint.TextColor3 = C.TEXT3
					KbHint.TextSize = 7
					KbHint.TextXAlignment = Enum.TextXAlignment.Center
					KbHint.ZIndex = 5
					KbHint.Visible = false
					KbHint.Parent = Row
				end

				local ToggleBG = Instance.new("Frame")
				ToggleBG.BackgroundColor3 = C.TOG_BG
				ToggleBG.BorderSizePixel = 0
				ToggleBG.Size = UDim2.new(0, 38, 0, 20)
				ToggleBG.Position = UDim2.new(1, -54, 0.5, -10)
				ToggleBG.ZIndex = 4
				ToggleBG.Parent = Row
				MakeCorner(ToggleBG, 10)

				local Knob = Instance.new("TextButton")
				Knob.BackgroundColor3 = isOn and C.TOG_ON or C.TOG_OFF
				Knob.BorderSizePixel = 0
				Knob.Size = UDim2.new(0, 16, 0, 16)
				Knob.Position = isOn and UDim2.new(0, 18, 0.5, -8) or UDim2.new(1, -34, 0.5, -8)
				Knob.Text = ""
				Knob.ZIndex = 5
				Knob.Parent = ToggleBG
				MakeCorner(Knob, 8)

				local Dot = Instance.new("Frame")
				Dot.BackgroundColor3 = C.TOG_BG
				Dot.BorderSizePixel = 0
				Dot.Size = UDim2.new(0, 8, 0, 8)
				Dot.Position = UDim2.new(0.5, -4, 0.5, -4)
				Dot.ZIndex = 6
				Dot.Parent = Knob
				MakeCorner(Dot, 4)

				local function updateToggle()
					if isOn then
						Tween(Knob, {Position = UDim2.new(0, 18, 0.5, -8), BackgroundColor3 = C.TOG_ON}, 0.2)
					else
						Tween(Knob, {Position = UDim2.new(1, -34, 0.5, -8), BackgroundColor3 = C.TOG_OFF}, 0.2)
					end
				end

				local function doToggle()
					isOn = not isOn
					updateToggle()
					if callback then callback(isOn) end
				end

				Knob.MouseButton1Click:Connect(doToggle)

				if showKeybind then
					local function applyKey(kc)
						boundKey = kc
						if kc then
							KeyChip.Text = KeyName(kc)
							Tween(KeyChip, {TextColor3 = C.KEYBIND_ACT, BackgroundColor3 = Color3.fromRGB(28, 28, 40)}, 0.1)
						else
							KeyChip.Text = "None"
							Tween(KeyChip, {TextColor3 = C.TEXT3, BackgroundColor3 = C.KEYBIND_BG}, 0.1)
						end
						if keyConn then keyConn:Disconnect(); keyConn = nil end
						if kc then
							keyConn = UserInputService.InputBegan:Connect(function(input, gp)
								if not gp and input.KeyCode == kc then doToggle() end
							end)
						end
					end

					if boundKey then applyKey(boundKey) end

					KeyChip.MouseButton1Click:Connect(function()
						if listeningForKey then return end
						listeningForKey = true
						KeyChip.Text = "..."
						Tween(KeyChip, {TextColor3 = C.TEXT1, BackgroundColor3 = Color3.fromRGB(35, 35, 55)}, 0.1)
						if keyConn then keyConn:Disconnect(); keyConn = nil end
						local listenConn
						listenConn = UserInputService.InputBegan:Connect(function(input, gp)
							if gp then return end
							listeningForKey = false
							listenConn:Disconnect()
							if input.KeyCode == Enum.KeyCode.Escape then
								applyKey(nil)
							elseif input.UserInputType == Enum.UserInputType.Keyboard then
								applyKey(input.KeyCode)
							end
						end)
					end)

					KeyChip.MouseEnter:Connect(function()
						if not listeningForKey then KbHint.Visible = true end
					end)
					KeyChip.MouseLeave:Connect(function()
						KbHint.Visible = false
					end)
				end

				local ctrl = {}
				function ctrl:Set(val) isOn = val; updateToggle(); if callback then callback(isOn) end end
				function ctrl:Get() return isOn end
				function ctrl:SetKeybind(kc)
					if showKeybind and KeyChip then
						boundKey = kc
						if kc then
							KeyChip.Text = KeyName(kc)
							Tween(KeyChip, {TextColor3 = C.KEYBIND_ACT, BackgroundColor3 = Color3.fromRGB(28, 28, 40)}, 0.1)
						else
							KeyChip.Text = "None"
							Tween(KeyChip, {TextColor3 = C.TEXT3, BackgroundColor3 = C.KEYBIND_BG}, 0.1)
						end
						if keyConn then keyConn:Disconnect(); keyConn = nil end
						if kc then
							keyConn = UserInputService.InputBegan:Connect(function(input, gp)
								if not gp and input.KeyCode == kc then doToggle() end
							end)
						end
					end
				end
				function ctrl:GetKeybind() return boundKey end
				return ctrl
			end

