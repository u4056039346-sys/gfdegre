	MakeCorner(Main, 10)

	local dragging = false
	local grabOffsetX, grabOffsetY = 0, 0
	local targetX, targetY = 0, 0
	local velX, velY = 0, 0
	local hasMoved = false

	Main.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			hasMoved = false
			grabOffsetX = input.Position.X - Main.AbsolutePosition.X
			grabOffsetY = input.Position.Y - Main.AbsolutePosition.Y
			targetX = Main.AbsolutePosition.X
			targetY = Main.AbsolutePosition.Y
			velX, velY = 0, 0
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			hasMoved = true
			targetX = input.Position.X - grabOffsetX
			targetY = input.Position.Y - grabOffsetY
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

