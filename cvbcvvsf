		if not dragging or not hasMoved then return end
		local curX = Main.AbsolutePosition.X
		local curY = Main.AbsolutePosition.Y
		local forceX = (targetX - curX) * STIFFNESS - velX * DAMPING
		local forceY = (targetY - curY) * STIFFNESS - velY * DAMPING
		velX = velX + forceX * dt
		velY = velY + forceY * dt
		Main.Position = UDim2.new(0, curX + velX * dt, 0, curY + velY * dt)
	end)

