			-- Tab:AddDropdown
			-- Sig A (full):  label, description, options, default, callback, subTab
			-- Sig B (short): label, options, default, callback, subTab  (no description)
			------------------------------------------------------------
			function Tab:AddDropdown(label, description, options, default, callback, subTab)
				-- detect old 5-arg signature: (label, options, default, callback, subTab)
				if type(description) == "table" then
					subTab      = callback
					callback    = default
					default     = options
					options     = description
					description = nil
				end
				if type(default) == "function" then
					subTab = callback; callback = default; default = options[1]
