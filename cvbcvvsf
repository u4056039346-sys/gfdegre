			------------------------------------------------------------
			-- Tab:AddSlider
			-- Sig A (table-desc): label, { Min,Max,Default,Rounding,Callback,Desc }, subTab
			-- Sig B (nums):       label, min, max, default, callback, subTab
			-- Sig C (full args):  label, description, min, max, default, callback, subTab
			------------------------------------------------------------
			function Tab:AddSlider(label, description, min, max, default, callback, subTab)
				local rounding = nil
				if type(description) == "table" then
					local t = description
					subTab      = min
					label       = t.Text or t.Label or label
					min         = t.Min or 0
					max         = t.Max or 100
					default     = t.Default or min
					rounding    = t.Rounding
					callback    = t.Callback
					description = t.Desc or t.Description or nil
				elseif type(description) == "number" then
					-- old 6-arg: (label, min, max, default, callback, subTab)
					subTab      = callback
					callback    = default
					default     = max
					max         = min
					min         = description
					description = nil
				end

				local frame = getFrame(subTab)
				if not frame then return end

				local value = RoundValue(default or min, min, max, rounding)

				local Row = Instance.new("Frame")
				Row.BackgroundColor3 = C.ITEM
				Row.BorderSizePixel = 0
				Row.Size = UDim2.new(1, 0, 0, ROW_H)
				Row.ZIndex = 3
				Row.Parent = frame
				MakeCorner(Row, 4)

				-- reserve space for value text + track on the right
				PlaceLabelDesc(Row, label, description, -240)

				local ValueTxt = Instance.new("TextLabel")
				ValueTxt.BackgroundTransparency = 1
				ValueTxt.Size = UDim2.new(0, 150, 0, 6)        -- same height as TrackBG
				ValueTxt.Position = UDim2.new(0.45, 0, 0.5, -3) -- same Y as TrackBG
				ValueTxt.TextYAlignment = Enum.TextYAlignment.Center
				ValueTxt.Font = Enum.Font.GothamBold
				ValueTxt.Text = FormatValue(value, rounding)
				ValueTxt.TextColor3 = C.ACCENT_DIM
				ValueTxt.TextSize = 12
				ValueTxt.TextXAlignment = Enum.TextXAlignment.Right
				ValueTxt.ZIndex = 4
				ValueTxt.Parent = Row

				local TrackBG = Instance.new("Frame")
				TrackBG.BackgroundColor3 = Color3.fromRGB(33, 33, 44)
				TrackBG.BorderSizePixel = 0
				TrackBG.Size = UDim2.new(1, -400, 0, 6)
				TrackBG.Position = UDim2.new(0.65, 62, 0.5, -3)
				TrackBG.ZIndex = 4
				TrackBG.Parent = Row
				MakeCorner(TrackBG, 3)

				local initPct = (max ~= min) and ((value - min) / (max - min)) or 0

				local Fill = Instance.new("Frame")
				Fill.BackgroundColor3 = C.ACCENT
				Fill.BorderSizePixel = 0
				Fill.Size = UDim2.new(initPct, 0, 1, 0)
				Fill.ZIndex = 5
				Fill.Parent = TrackBG
				MakeCorner(Fill, 3)

				local SliderKnob = Instance.new("TextButton")
				SliderKnob.BackgroundColor3 = Color3.fromRGB(200, 200, 215)
				SliderKnob.BorderSizePixel = 0
				SliderKnob.Size = UDim2.new(0, 10, 0, 10)
				SliderKnob.Position = UDim2.new(initPct, -5, 0.5, -5)
				SliderKnob.Text = ""
				SliderKnob.ZIndex = 6
				SliderKnob.Parent = TrackBG
				MakeCorner(SliderKnob, 4)

				local draggingSlider = false
				SliderKnob.MouseButton1Down:Connect(function() draggingSlider = true end)
				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingSlider = false end
				end)
				UserInputService.InputChanged:Connect(function(input)
					if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
						local absPos  = TrackBG.AbsolutePosition.X
						local absSize = TrackBG.AbsoluteSize.X
						local rawPct  = math.clamp((input.Position.X - absPos) / absSize, 0, 1)
						local rawVal  = min + (max - min) * rawPct
						value = RoundValue(rawVal, min, max, rounding)
						local pct = (max ~= min) and ((value - min) / (max - min)) or 0
						ValueTxt.Text = FormatValue(value, rounding)
						Fill.Size = UDim2.new(pct, 0, 1, 0)
						SliderKnob.Position = UDim2.new(pct, -5, 0.5, -5)
						if callback then callback(value) end
					end
				end)

				local ctrl = {}
				function ctrl:Set(v)
					value = RoundValue(v, min, max, rounding)
					local pct = (max ~= min) and ((value - min) / (max - min)) or 0
					ValueTxt.Text = FormatValue(value, rounding)
					Fill.Size = UDim2.new(pct, 0, 1, 0)
					SliderKnob.Position = UDim2.new(pct, -5, 0.5, -5)
					if callback then callback(value) end
				end
				function ctrl:Get() return value end
				return ctrl
			end

			------------------------------------------------------------
			-- Tab:AddRangeSlider
			-- Sig A (table): { Text, Options={Min,Max,Default,Rounding,Desc}, Callback, SubTab }
			-- Sig B (args):  label, options, callback, subTab
			------------------------------------------------------------
			function Tab:AddRangeSlider(label, options, callback, subTab)
				if type(label) == "table" then
					local t = label
					options  = t.Options or {}
					callback = t.Callback or t.callback
					subTab   = t.SubTab or t.subTab
					label    = t.Text or t.Label or ""
				end

				options = options or {}
				local min         = options.Min     or 0
				local max         = options.Max     or 100
				local defLow      = options.Default and options.Default[1] or min
				local defHigh     = options.Default and options.Default[2] or max
				local rounding    = options.Rounding or nil
				local description = options.Desc or options.Description or nil

				local frame = getFrame(subTab)
				if not frame then return end

				local valLow  = RoundValue(defLow,  min, max, rounding)
				local valHigh = RoundValue(defHigh, min, max, rounding)

				local Row = Instance.new("Frame")
				Row.BackgroundColor3 = C.ITEM
				Row.BorderSizePixel = 0
				Row.Size = UDim2.new(1, 0, 0, ROW_H)
				Row.ZIndex = 3
				Row.Parent = frame
				MakeCorner(Row, 4)

				-- same rightOffset as Slider so the two look identical
				PlaceLabelDesc(Row, label, description, -240)

				local ValueTxt = Instance.new("TextLabel")
				ValueTxt.BackgroundTransparency = 1
				ValueTxt.Size = UDim2.new(0, 80, 0, 6)           -- same height as TrackBG  
				ValueTxt.Position = UDim2.new(0.45, 70, 0.5, -3) -- same Y as TrackBG
				ValueTxt.TextYAlignment = Enum.TextYAlignment.Center
				ValueTxt.Font = Enum.Font.GothamBold
				ValueTxt.Text = FormatValue(valLow, rounding) .. ", " .. FormatValue(valHigh, rounding)
				ValueTxt.TextColor3 = C.ACCENT_DIM
				ValueTxt.TextSize = 12
				ValueTxt.TextXAlignment = Enum.TextXAlignment.Right
				ValueTxt.ZIndex = 4
				ValueTxt.Parent = Row

				local TrackBG = Instance.new("Frame")
				TrackBG.BackgroundColor3 = Color3.fromRGB(33, 33, 44)
				TrackBG.BorderSizePixel = 0
				TrackBG.Size = UDim2.new(1, -400, 0, 6)
				TrackBG.Position = UDim2.new(0.65, 62, 0.5, -3)
				TrackBG.ZIndex = 4
				TrackBG.Parent = Row
				MakeCorner(TrackBG, 3)

				local Fill = Instance.new("Frame")
				Fill.BackgroundColor3 = C.ACCENT
				Fill.BorderSizePixel = 0
				Fill.ZIndex = 5
				Fill.Parent = TrackBG
				MakeCorner(Fill, 3)

				local KnobLow = Instance.new("TextButton")
				KnobLow.BackgroundColor3 = Color3.fromRGB(200, 200, 215)
				KnobLow.BorderSizePixel = 0
				KnobLow.Size = UDim2.new(0, 10, 0, 10)
				KnobLow.Text = ""
				KnobLow.ZIndex = 7
				KnobLow.Parent = TrackBG
				MakeCorner(KnobLow, 4)

				local KnobHigh = Instance.new("TextButton")
				KnobHigh.BackgroundColor3 = Color3.fromRGB(200, 200, 215)
				KnobHigh.BorderSizePixel = 0
				KnobHigh.Size = UDim2.new(0, 10, 0, 10)
				KnobHigh.Text = ""
				KnobHigh.ZIndex = 7
				KnobHigh.Parent = TrackBG
				MakeCorner(KnobHigh, 4)

				local function updateVisuals()
					local pctLow  = (max ~= min) and ((valLow  - min) / (max - min)) or 0
					local pctHigh = (max ~= min) and ((valHigh - min) / (max - min)) or 0
					Fill.Size     = UDim2.new(pctHigh - pctLow, 0, 1, 0)
					Fill.Position = UDim2.new(pctLow, 0, 0, 0)
					KnobLow.Position  = UDim2.new(pctLow,  -5, 0.5, -5)
					KnobHigh.Position = UDim2.new(pctHigh, -5, 0.5, -5)
					ValueTxt.Text = FormatValue(valLow, rounding) .. ", " .. FormatValue(valHigh, rounding)
				end

				updateVisuals()

				local draggingLow, draggingHigh = false, false
				KnobLow.MouseButton1Down:Connect(function() draggingLow = true end)
				KnobHigh.MouseButton1Down:Connect(function() draggingHigh = true end)
				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						draggingLow = false; draggingHigh = false
					end
				end)
				UserInputService.InputChanged:Connect(function(input)
					if not (draggingLow or draggingHigh) then return end
					if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
					local absPos  = TrackBG.AbsolutePosition.X
					local absSize = TrackBG.AbsoluteSize.X
					local rawPct  = math.clamp((input.Position.X - absPos) / absSize, 0, 1)
					local rawVal  = min + (max - min) * rawPct
					if draggingLow then
						valLow = RoundValue(math.min(rawVal, valHigh), min, max, rounding)
					elseif draggingHigh then
						valHigh = RoundValue(math.max(rawVal, valLow), min, max, rounding)
					end
					updateVisuals()
					if callback then callback(valLow, valHigh) end
				end)

				local ctrl = {}
				function ctrl:Set(low, high)
					valLow  = RoundValue(math.min(low, high), min, max, rounding)
					valHigh = RoundValue(math.max(low, high), min, max, rounding)
					updateVisuals()
					if callback then callback(valLow, valHigh) end
				end
				function ctrl:Get() return valLow, valHigh end
				return ctrl
			end

