local function Tween(obj, props, t)
	local ti = TweenInfo.new(t or 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	TweenService:Create(obj, ti, props):Play()
end

local function MakeCorner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 6)
	c.Parent = parent
	return c
end

local function MakePadding(parent, top, bottom, left, right)
	local p = Instance.new("UIPadding")
	p.PaddingTop = UDim.new(0, top or 0)
	p.PaddingBottom = UDim.new(0, bottom or 0)
	p.PaddingLeft = UDim.new(0, left or 0)
	p.PaddingRight = UDim.new(0, right or 0)
	p.Parent = parent
	return p
end

local function MakeList(parent, padding, fillDirection)
	local l = Instance.new("UIListLayout")
	l.Padding = UDim.new(0, padding or 8)
	l.SortOrder = Enum.SortOrder.LayoutOrder
	l.FillDirection = fillDirection or Enum.FillDirection.Vertical
	l.Parent = parent
	return l
end

local function FormatValue(value, rounding)
	if rounding == nil or rounding == 0 then
		return tostring(math.floor(value + 0.5))
	end
	local stepStr = tostring(rounding)
	local dotPos = stepStr:find("%.")
	if not dotPos then
		return tostring(math.floor(value / rounding + 0.5) * rounding)
	end
	local decimals = #stepStr - dotPos
	local rounded = math.floor(value / rounding + 0.5) * rounding
	return string.format("%." .. decimals .. "f", rounded)
end

local function RoundValue(value, min, max, rounding)
	if rounding == nil or rounding == 0 then
		return math.floor(math.clamp(value, min, max) + 0.5)
	end
	local snapped = math.floor(value / rounding + 0.5) * rounding
	return math.clamp(snapped, min, max)
end

