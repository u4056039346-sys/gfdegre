			-- --------------------------------------------------------
			-- Tab:AddDropdown  (Multi + Player SpecialType)
			-- --------------------------------------------------------
			function Tab:AddDropdown(a, b, c, d, e)
				if type(b) == "table" and b.Values then
					-- new API: (idx, opts)
					local o    = b
					local ctrl = Tab:_addDropdownImpl(
						o.Text or a, o.Values, o.Default, o.Callback, o.SubTab,
						o.Multi or false, o.SpecialType
					)
					Options[a] = ctrl
					return ctrl
				else
					-- old positional API
					return Tab:_addDropdownImpl(a, b, c, d, e, false, nil)
				end
			end

			function Tab:_addDropdownImpl(label, options, default, callback, subTab, multi, specialType)
				local frame = getFrame(subTab)
				if not frame then return end

				-- Player special type: populate with current players
				if specialType == "Player" then
					options = {}
					for _, p in ipairs(Players:GetPlayers()) do
						table.insert(options, p.Name)
					end
					Players.PlayerAdded:Connect(function(p)
						table.insert(options, p.Name)
					end)
					Players.PlayerRemoving:Connect(function(p)
						for i, n in ipairs(options) do
							if n == p.Name then table.remove(options, i) break end
						end
					end)
				end

				local selected   = {}
				local open       = false

				-- Resolve default
				if multi then
					if type(default) == "table" then
						selected = default
					elseif type(default) == "number" and options[default] then
						selected[options[default]] = true
					elseif type(default) == "string" then
						selected[default] = true
					else
						-- default first
						if options[1] then selected[options[1]] = true end
					end
				else
					if type(default) == "number" then
						selected = options[default] or options[1] or ""
					elseif type(default) == "string" then
						selected = default
					else
						selected = options[1] or ""
					end
				end

				local function getDisplayText()
					if multi then
						local parts = {}
						for k, v in pairs(selected) do if v then table.insert(parts, k) end end
						return #parts > 0 and table.concat(parts, ", ") or "None"
					end
					return tostring(selected)
				end

				local Row = Instance.new("Frame")
				Row.BackgroundColor3  = C.ITEM
				Row.BorderSizePixel   = 0
				Row.Size              = UDim2.new(1, 0, 0, 49)
				Row.ClipsDescendants  = false
				Row.ZIndex            = 10
				Row.Parent            = frame
				MakeCorner(Row, 4)

				local LabelTxt = Instance.new("TextLabel")
				LabelTxt.BackgroundTransparency = 1
				LabelTxt.Size           = UDim2.new(1, -16, 0, 20)
				LabelTxt.Position       = UDim2.new(0, 16, 0, 6)
				LabelTxt.Font           = Enum.Font.GothamBold
				LabelTxt.Text           = label
				LabelTxt.TextColor3     = C.TEXT1
				LabelTxt.TextSize       = 12
				LabelTxt.TextXAlignment = Enum.TextXAlignment.Left
				LabelTxt.ZIndex         = 11
				LabelTxt.Parent         = Row

				local DropBtn = Instance.new("TextButton")
				DropBtn.BackgroundColor3  = C.INPUT_BG
				DropBtn.BorderSizePixel   = 0
				DropBtn.Size              = UDim2.new(1, -32, 0, 22)
				DropBtn.Position          = UDim2.new(0, 16, 0, 22)
				DropBtn.Font              = Enum.Font.Gotham
				DropBtn.Text              = getDisplayText()
				DropBtn.TextColor3        = C.TEXT2
				DropBtn.TextSize          = 11
				DropBtn.TextXAlignment    = Enum.TextXAlignment.Left
				DropBtn.ZIndex            = 11
				DropBtn.Parent            = Row
				MakeCorner(DropBtn, 4)
				MakePadding(DropBtn, 0, 0, 8, 24)

				local DropArrow = Instance.new("TextLabel")
				DropArrow.BackgroundTransparency = 1
				DropArrow.Size           = UDim2.new(0, 20, 1, 0)
				DropArrow.Position       = UDim2.new(1, -22, 0, 0)
				DropArrow.Font           = Enum.Font.GothamBold
				DropArrow.Text           = "▾"
				DropArrow.TextColor3     = C.TEXT3
				DropArrow.TextSize       = 12
				DropArrow.ZIndex         = 12
				DropArrow.Parent         = DropBtn

				local DropList = Instance.new("Frame")
				DropList.BackgroundColor3 = C.DROPDOWN_BG
				DropList.BorderSizePixel  = 0
				DropList.Size             = UDim2.new(1, -32, 0, #options * 26 + 4)
				DropList.Position         = UDim2.new(0, 16, 0, 47)
				DropList.Visible          = false
				DropList.ZIndex           = 20
				DropList.Parent           = Row
				MakeCorner(DropList, 4)
				MakePadding(DropList, 2, 2, 4, 4)
				MakeList(DropList, 2)

				local ctrl = MakeCtrl({Value = selected})

				local optBtns = {}
				local function refreshHighlights()
					for _, ob in ipairs(optBtns) do
						local isSelected = multi and (selected[ob.Text] == true) or (ob.Text == selected)
						ob.TextColor3 = isSelected and C.TEXT1 or C.TEXT2
					end
				end

				for _, opt in ipairs(options) do
					local OptBtn = Instance.new("TextButton")
					OptBtn.BackgroundColor3    = C.DROPDOWN_BG
					OptBtn.BackgroundTransparency = 1
					OptBtn.BorderSizePixel     = 0
					OptBtn.Size                = UDim2.new(1, 0, 0, 22)
					OptBtn.Font                = Enum.Font.Gotham
					OptBtn.Text                = opt
					OptBtn.TextColor3          = C.TEXT2
					OptBtn.TextSize            = 11
					OptBtn.TextXAlignment      = Enum.TextXAlignment.Left
					OptBtn.ZIndex              = 21
					OptBtn.Parent              = DropList
					MakePadding(OptBtn, 0, 0, 6, 6)
					MakeCorner(OptBtn, 3)
					table.insert(optBtns, OptBtn)

					OptBtn.MouseEnter:Connect(function() Tween(OptBtn, {BackgroundTransparency = 0.7}, 0.1) end)
					OptBtn.MouseLeave:Connect(function() Tween(OptBtn, {BackgroundTransparency = 1}, 0.1) end)

					OptBtn.MouseButton1Click:Connect(function()
						if multi then
							selected[opt] = not selected[opt]
						else
							selected = opt
							open = false
							DropList.Visible = false
							Tween(DropArrow, {Rotation = 0}, 0.15)
						end
						ctrl.Value    = selected
						DropBtn.Text  = getDisplayText()
						refreshHighlights()
						if callback then callback(selected) end
						ctrl:_fire()
					end)
				end
				refreshHighlights()

				DropBtn.MouseButton1Click:Connect(function()
					open = not open
					DropList.Visible = open
					Tween(DropArrow, {Rotation = open and 180 or 0}, 0.15)
				end)

				function ctrl:Set(v)
					selected     = v
					self.Value   = v
					DropBtn.Text = getDisplayText()
					refreshHighlights()
					if callback then callback(selected) end
					self:_fire()
				end
				function ctrl:SetValue(v) self:Set(v) end
				function ctrl:Get() return selected end
				return ctrl
			end

			-- --------------------------------------------------------
			-- Tab:AddLabel  (with :AddColorPicker and :AddKeyPicker)
