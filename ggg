			-- --------------------------------------------------------
			-- Tab:AddSlider
			-- --------------------------------------------------------
			function Tab:AddSlider(a, b, c, d, e, f, g)
				local label, description, min, max, default, callback, subTab, rounding, suffix
				if type(b) == "table" then
					label = a; local o = b
					description = o.Tooltip; min = o.Min; max = o.Max
					default = o.Default; callback = o.Callback; subTab = o.SubTab
					rounding = o.Rounding or 0; suffix = o.Suffix or ""
					-- register in Options
					local idx = a
					local ctrl = Tab:_addSliderImpl(label, description, min, max, default, callback, subTab, rounding, suffix)
					Options[idx] = ctrl
					return ctrl
				elseif type(b) == "number" then
					label = a; min = b; max = c; default = d; callback = e; subTab = f
					return Tab:_addSliderImpl(label, nil, min, max, default, callback, subTab, 0, "")
				else
					label = a; description = b; min = c; max = d; default = e; callback = f; subTab = g
					return Tab:_addSliderImpl(label, description, min, max, default, callback, subTab, 0, "")
				end
			end

			function Tab:_addSliderImpl(label, description, min, max, default, callback, subTab, rounding, suffix)
				rounding = rounding or 0
				suffix   = suffix   or ""
				local frame = getFrame(subTab)
				if not frame then return end

				local value = default or min
				local function fmt(v)
					if rounding > 0 then
						return string.format("%." .. rounding .. "f", v) .. suffix
					end
					return tostring(math.floor(v + 0.5)) .. suffix
				end

				local Row = Instance.new("Frame")
				Row.BackgroundColor3 = C.ITEM
				Row.BorderSizePixel  = 0
				Row.Size             = UDim2.new(1, 0, 0, description and 68 or 56)
				Row.ZIndex           = 3
				Row.Parent           = frame
				MakeCorner(Row, 4)

				local LabelTxt = Instance.new("TextLabel")
				LabelTxt.BackgroundTransparency = 1
				LabelTxt.Size           = UDim2.new(1, -70, 0, 20)
				LabelTxt.Position       = UDim2.new(0, 16, 0, 6)
				LabelTxt.Font           = Enum.Font.GothamBold
				LabelTxt.Text           = label
				LabelTxt.TextColor3     = C.TEXT1
				LabelTxt.TextSize       = 12
				LabelTxt.TextXAlignment = Enum.TextXAlignment.Left
				LabelTxt.ZIndex         = 4
				LabelTxt.Parent         = Row

				local ValueTxt = Instance.new("TextLabel")
				ValueTxt.BackgroundTransparency = 1
				ValueTxt.Size           = UDim2.new(0, 60, 0, 20)
				ValueTxt.Position       = UDim2.new(1, -74, 0, 6)
				ValueTxt.Font           = Enum.Font.GothamBold
				ValueTxt.Text           = fmt(value)
				ValueTxt.TextColor3     = C.ACCENT_DIM
				ValueTxt.TextSize       = 12
				ValueTxt.TextXAlignment = Enum.TextXAlignment.Right
				ValueTxt.ZIndex         = 4
				ValueTxt.Parent         = Row

				if description then
					local DescTxt = Instance.new("TextLabel")
					DescTxt.BackgroundTransparency = 1
					DescTxt.Size           = UDim2.new(1, -16, 0, 14)
					DescTxt.Position       = UDim2.new(0, 16, 0, 25)
					DescTxt.Font           = Enum.Font.Gotham
					DescTxt.Text           = description
					DescTxt.TextColor3     = C.TEXT3
					DescTxt.TextSize       = 10
					DescTxt.ZIndex         = 4
					DescTxt.Parent         = Row
				end

				local TrackBG = Instance.new("Frame")
				TrackBG.BackgroundColor3 = Color3.fromRGB(25, 25, 32)
				TrackBG.BorderSizePixel  = 0
				TrackBG.Size             = UDim2.new(1, -32, 0, 4)
				TrackBG.Position         = UDim2.new(0, 16, 1, -18)
				TrackBG.ZIndex           = 4
				TrackBG.Parent           = Row
				MakeCorner(TrackBG, 2)

				local Fill = Instance.new("Frame")
				Fill.BackgroundColor3 = C.ACCENT
				Fill.BorderSizePixel  = 0
				Fill.Size             = UDim2.new((value - min) / (max - min), 0, 1, 0)
				Fill.ZIndex           = 5
				Fill.Parent           = TrackBG
				MakeCorner(Fill, 2)

				local SliderKnob = Instance.new("TextButton")
				SliderKnob.BackgroundColor3 = C.TEXT1
				SliderKnob.BorderSizePixel  = 0
				SliderKnob.Size             = UDim2.new(0, 12, 0, 12)
				SliderKnob.Position         = UDim2.new((value - min) / (max - min), -6, 0.5, -6)
				SliderKnob.Text             = ""
				SliderKnob.ZIndex           = 6
				SliderKnob.Parent           = TrackBG
				MakeCorner(SliderKnob, 6)

				local draggingSlider = false
				SliderKnob.MouseButton1Down:Connect(function() draggingSlider = true end)
				UserInputService.InputEnded:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1 then draggingSlider = false end
				end)

				local ctrl = MakeCtrl({Value = value})

				UserInputService.InputChanged:Connect(function(i)
					if draggingSlider and i.UserInputType == Enum.UserInputType.MouseMovement then
						local absPos  = TrackBG.AbsolutePosition.X
						local absSize = TrackBG.AbsoluteSize.X
						local pct     = math.clamp((i.Position.X - absPos) / absSize, 0, 1)
						local raw     = min + (max - min) * pct
						if rounding == 0 then
							value = math.floor(raw + 0.5)
						else
							local factor = 10^rounding
							value = math.floor(raw * factor + 0.5) / factor
						end
						ctrl.Value    = value
						ValueTxt.Text = fmt(value)
						Fill.Size     = UDim2.new(pct, 0, 1, 0)
						SliderKnob.Position = UDim2.new(pct, -6, 0.5, -6)
						if callback then callback(value) end
						ctrl:_fire()
					end
				end)

				function ctrl:Set(v)
					value = math.clamp(v, min, max)
					self.Value = value
					local pct = (value - min) / (max - min)
					ValueTxt.Text = fmt(value)
					Fill.Size     = UDim2.new(pct, 0, 1, 0)
					SliderKnob.Position = UDim2.new(pct, -6, 0.5, -6)
					if callback then callback(value) end
					self:_fire()
				end
				function ctrl:SetValue(v) self:Set(v) end
				function ctrl:Get() return value end
				return ctrl
			end

