				-- ------------------------------------------------
				-- :AddKeyPicker (chained on label)
				-- ------------------------------------------------
				function labelCtrl:AddKeyPicker(idx, opts)
					opts = opts or {}
					local defKey    = opts.Default or "None"
					local mode      = opts.Mode    or "Toggle"
					local noUI      = opts.NoUI    or false
					local text      = opts.Text    or idx
					local cb        = opts.Callback
					local changedCb = opts.ChangedCallback
					local syncToggle = opts.SyncToggleState or false

					-- Small key label on the right of the row
					local KeyLbl = Instance.new("TextButton")
					KeyLbl.BackgroundColor3    = C.KEYBIND_BG
					KeyLbl.BorderSizePixel     = 0
					KeyLbl.Size               = UDim2.new(0, 0, 0, 20)
					KeyLbl.AutomaticSize      = Enum.AutomaticSize.X
					KeyLbl.Position           = UDim2.new(1, -8, 0.5, -10)
					KeyLbl.AnchorPoint        = Vector2.new(1, 0)
					KeyLbl.Font               = Enum.Font.Gotham
					KeyLbl.Text               = "[" .. defKey .. "]"
					KeyLbl.TextColor3         = C.ACCENT_DIM
					KeyLbl.TextSize           = 10
					KeyLbl.ZIndex             = 5
					KeyLbl.Parent             = Row
					MakeCorner(KeyLbl, 3)
					MakePadding(KeyLbl, 0, 0, 4, 4)

					-- Shrink label text so it doesn't overlap
					LabelTxt.Size = UDim2.new(1, -80, 1, 0)

					local ctrl = MakeCtrl({Value = defKey, _keyLabel = KeyLbl})
					ctrl._mode       = mode
					ctrl._state      = false  -- for Toggle mode
					ctrl._clickCbs   = {}
					ctrl._syncToggle = nil

					if changedCb then ctrl:OnChanged(changedCb) end
					if cb then
						ctrl._cbFn = cb
					end

					function ctrl:OnClick(fn) table.insert(self._clickCbs, fn) end
					function ctrl:GetState() return self._state end
					function ctrl:SetValue(t)
						local k, m = t[1], t[2]
						self.Value    = k
						self._mode    = m or self._mode
						KeyLbl.Text   = "[" .. k .. "]"
						self:_fire()
					end

					-- Keybind: register global listener
					local conn = UserInputService.InputBegan:Connect(function(input, gp)
						if gp then return end
						local keyName
						if input.UserInputType == Enum.UserInputType.Keyboard then
							keyName = input.KeyCode.Name
						elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
							keyName = "MB1"
						elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
							keyName = "MB2"
						end
						if keyName == ctrl.Value then
							if ctrl._mode == "Toggle" then
								ctrl._state = not ctrl._state
								for _, fn in ipairs(ctrl._clickCbs) do fn(ctrl._state) end
								if ctrl._cbFn then ctrl._cbFn(ctrl._state) end
								if ctrl._syncToggle then
									ctrl._syncToggle:Set(ctrl._state)
								end
							elseif ctrl._mode == "Hold" then
								ctrl._state = true
								if ctrl._cbFn then ctrl._cbFn(true) end
							elseif ctrl._mode == "Always" then
								if ctrl._cbFn then ctrl._cbFn(true) end
							end
						end
					end)
					local conn2 = UserInputService.InputEnded:Connect(function(input)
						local keyName
						if input.UserInputType == Enum.UserInputType.Keyboard then
							keyName = input.KeyCode.Name
						elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
							keyName = "MB1"
						elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
							keyName = "MB2"
						end
						if keyName == ctrl.Value and ctrl._mode == "Hold" then
							ctrl._state = false
							if ctrl._cbFn then ctrl._cbFn(false) end
						end
					end)
					table.insert(NeronLib._connections, conn)
					table.insert(NeronLib._connections, conn2)

					-- Click swatch to re-bind
					KeyLbl.MouseButton1Click:Connect(function()
						openKeyPicker(ctrl)
					end)

					-- Add to keybind menu (if not NoUI)
					if not noUI then
						local KBRow = Instance.new("Frame")
						KBRow.BackgroundTransparency = 1
						KBRow.BorderSizePixel        = 0
						KBRow.Size                   = UDim2.new(1, 0, 0, 20)
						KBRow.ZIndex                 = 21
						KBRow.Parent                 = KBMenuFrame

						local KBName = Instance.new("TextLabel")
						KBName.BackgroundTransparency = 1
						KBName.Size           = UDim2.new(1, -50, 1, 0)
						KBName.Font           = Enum.Font.Gotham
						KBName.Text           = text
						KBName.TextColor3     = C.TEXT2
						KBName.TextSize       = 10
						KBName.TextXAlignment = Enum.TextXAlignment.Left
						KBName.ZIndex         = 22
						KBName.Parent         = KBRow

						local KBKey = Instance.new("TextLabel")
						KBKey.BackgroundTransparency = 1
						KBKey.Size           = UDim2.new(0, 50, 1, 0)
						KBKey.Position       = UDim2.new(1, -50, 0, 0)
						KBKey.Font           = Enum.Font.Gotham
						KBKey.Text           = defKey
						KBKey.TextColor3     = C.ACCENT_DIM
						KBKey.TextSize       = 10
						KBKey.TextXAlignment = Enum.TextXAlignment.Right
						KBKey.ZIndex         = 22
						KBKey.Parent         = KBRow

						ctrl:OnChanged(function()
							KBKey.Text = ctrl.Value
						end)
					end

					-- Check if window toggle keybind
					if idx == "MenuKeybind" then
						NeronLib.ToggleKeybind = ctrl
						ctrl:OnChanged(function()
							-- map string key name to KeyCode
							local kc = Enum.KeyCode[ctrl.Value]
							if kc then NeronLib._toggleKey = kc end
						end)
					end

					Options[idx] = ctrl
					return ctrl
				end

				return labelCtrl
			end

			-- --------------------------------------------------------
			-- Tab:AddSeparator
			-- --------------------------------------------------------
			function Tab:AddSeparator(subTab)
				local frame = getFrame(subTab)
				if not frame then return end
				local Sep = Instance.new("Frame")
				Sep.BackgroundColor3 = C.DIVIDER
				Sep.BorderSizePixel  = 0
				Sep.Size             = UDim2.new(1, 0, 0, 1)
				Sep.ZIndex           = 3
				Sep.Parent           = frame
			end

			-- --------------------------------------------------------
			-- Tab:AddDependencyBox
			-- --------------------------------------------------------
			function Tab:AddDependencyBox(subTab)
				local frame = getFrame(subTab)
				if not frame then return end

				-- A dependency box is a container frame that can be shown/hidden
				local DepFrame = Instance.new("Frame")
				DepFrame.BackgroundTransparency = 1
				DepFrame.BorderSizePixel        = 0
				DepFrame.Size                   = UDim2.new(1, 0, 0, 0)
				DepFrame.AutomaticSize          = Enum.AutomaticSize.Y
				DepFrame.Visible                = false
				DepFrame.ZIndex                 = 3
				DepFrame.Parent                 = frame
				MakeList(DepFrame, 4)

				local depBox = {}
				depBox._frame        = DepFrame
				depBox._dependencies = {}
				depBox._parentDepBox = nil  -- set when nested

				-- Forward all Tab element methods onto the depBox
				-- so you can call depBox:AddToggle, depBox:AddSlider etc.
				local function makeDepFrame(st)
					-- returns DepFrame regardless of subtab (depbox ignores subtabs)
					return DepFrame
				end

				-- We wrap each method: replace getFrame with makeDepFrame
				local methods = {"_addToggleImpl","_addSliderImpl","_addTextboxImpl",
					"_addDropdownImpl","AddSeparator","AddLabel","AddButton","AddDivider"}

				-- Simpler: just expose AddToggle, AddSlider etc by binding directly
				for _, methodName in ipairs({
					"AddToggle","AddButton","AddSlider","AddTextbox",
					"AddDropdown","AddLabel","AddSeparator"
				}) do
					depBox[methodName] = function(self, ...)
						-- Temporarily redirect getFrame
						local oldGet = getFrame
						getFrame = makeDepFrame
						local result = Tab[methodName](Tab, ...)
						getFrame = oldGet
						return result
					end
				end

				function depBox:AddDependencyBox()
					-- Nested dep box
					local subDepBox = Tab:AddDependencyBox(subTab)
					subDepBox._frame.Parent = DepFrame
					subDepBox._parentDepBox = self
					return subDepBox
				end

				function depBox:SetupDependencies(deps)
					self._dependencies = deps
					local function evaluate()
						-- Check parent visibility first
						if self._parentDepBox and not self._parentDepBox._frame.Visible then
							self._frame.Visible = false
							return
						end
						local allMet = true
						for _, dep in ipairs(self._dependencies) do
							local toggle = dep[1]
							local expected = dep[2]
							if toggle.Value ~= expected then
								allMet = false
								break
							end
						end
						self._frame.Visible = allMet
					end

					-- Watch each toggle
					for _, dep in ipairs(self._dependencies) do
						local toggle = dep[1]
						toggle:OnChanged(function()
							evaluate()
						end)
						-- Also watch parent
						if self._parentDepBox then
							for _, pdep in ipairs(self._parentDepBox._dependencies) do
								pdep[1]:OnChanged(function() evaluate() end)
							end
						end
					end
					evaluate()
				end

				return depBox
			end

			-- Alias
			Tab.AddDivider = Tab.AddSeparator

			table.insert(Window._tabs, Tab)
			return Tab
		end -- AddTab

		return Category
	end -- AddCategory

	return Window
end -- CreateWindow

return NeronLib
