			local function makeButtonRow(parentFrame, label, description, callback, isSubBtn)
				local h = isSubBtn and 28 or (description and 49 or 36)
				local Row = Instance.new("TextButton")
				Row.BackgroundColor3 = isSubBtn and C.INPUT_BG or C.ITEM
				Row.BorderSizePixel  = 0
				Row.Size             = UDim2.new(1, isSubBtn and -8 or 0, 0, h)
				Row.Font             = Enum.Font.GothamBold
				Row.Text             = ""
				Row.ZIndex           = 3
				Row.Parent           = parentFrame
				MakeCorner(Row, 4)
				if isSubBtn then
					-- slight indent
					local inst = Instance.new("UIPadding")
					inst.PaddingLeft = UDim.new(0, 8)
					inst.Parent = Row
				end

				local LabelTxt = Instance.new("TextLabel")
				LabelTxt.BackgroundTransparency = 1
				LabelTxt.Size           = UDim2.new(1, -40, 0, 22)
				LabelTxt.Position       = UDim2.new(0, isSubBtn and 12 or 16, 0, description and 6 or 7)
				LabelTxt.Font           = Enum.Font.GothamBold
				LabelTxt.Text           = label
				LabelTxt.TextColor3     = isSubBtn and C.TEXT2 or C.TEXT1
				LabelTxt.TextSize       = isSubBtn and 11 or 12
				LabelTxt.TextXAlignment = Enum.TextXAlignment.Left
				LabelTxt.ZIndex         = 4
				LabelTxt.Parent         = Row

				if description and not isSubBtn then
					local DescTxt = Instance.new("TextLabel")
					DescTxt.BackgroundTransparency = 1
					DescTxt.Size           = UDim2.new(1, -40, 0, 16)
					DescTxt.Position       = UDim2.new(0, 16, 0, 27)
					DescTxt.Font           = Enum.Font.Gotham
					DescTxt.Text           = description
					DescTxt.TextColor3     = C.TEXT3
					DescTxt.TextSize       = 10
					DescTxt.TextXAlignment = Enum.TextXAlignment.Left
					DescTxt.ZIndex         = 4
					DescTxt.Parent         = Row
				end

				local Arrow = Instance.new("TextLabel")
				Arrow.BackgroundTransparency = 1
				Arrow.Size           = UDim2.new(0, 20, 0, 20)
				Arrow.Position       = UDim2.new(1, -28, 0.5, -10)
				Arrow.Font           = Enum.Font.GothamBold
				Arrow.Text           = isSubBtn and "›" or "›"
				Arrow.TextColor3     = C.ACCENT_DIM
				Arrow.TextSize       = 18
				Arrow.ZIndex         = 4
				Arrow.Parent         = Row

				Row.MouseEnter:Connect(function() Tween(Row, {BackgroundColor3 = C.ITEM_HOVER}, 0.1) end)
				Row.MouseLeave:Connect(function()
					Tween(Row, {BackgroundColor3 = isSubBtn and C.INPUT_BG or C.ITEM}, 0.1)
				end)

				-- DoubleClick support
				local lastClick = 0
				local btnCtrl   = {}

				btnCtrl._frame  = Row
				btnCtrl._doubleClick = false

				Row.MouseButton1Click:Connect(function()
					if btnCtrl._doubleClick then
						local now = tick()
						if now - lastClick < 0.4 then
							if callback then callback() end
						end
						lastClick = now
					else
						if callback then callback() end
					end
				end)

				-- Chaining: AddButton returns a ctrl that itself has AddButton
				function btnCtrl:AddButton(opts)
					local subLabel    = type(opts) == "table" and opts.Text     or opts
					local subCb       = type(opts) == "table" and opts.Func     or nil
					local subDouble   = type(opts) == "table" and opts.DoubleClick or false
					local sub = makeButtonRow(parentFrame, subLabel, nil, subCb, true)
					sub._doubleClick = subDouble
					return sub
