			function Tab:AddLabel(text, subTabOrWrap, subTab2)
				local wrap, subTab
				if type(subTabOrWrap) == "boolean" then
					wrap   = subTabOrWrap
					subTab = subTab2
				else
					wrap   = false
					subTab = subTabOrWrap
