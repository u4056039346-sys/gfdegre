-- ============================================================
-- Unload system
-- ============================================================
NeronLib.Unloaded      = false
NeronLib._unloadCbs    = {}
NeronLib._connections  = {}

function NeronLib:OnUnload(fn)
	table.insert(self._unloadCbs, fn)
end

function NeronLib:Unload()
	self.Unloaded = true
	for _, conn in ipairs(self._connections) do
		if typeof(conn) == "RBXScriptConnection" then conn:Disconnect() end
	end
	for _, fn in ipairs(self._unloadCbs) do
		pcall(fn)
	end
	-- Destroy all guis
	for _, gui in ipairs(game:GetService("CoreGui"):GetChildren()) do
		if gui.Name:sub(1, 9) == "NeronLib_" then gui:Destroy() end
	end
	WatermarkGui:Destroy()
end

