					Tween(IconLbl, {TextColor3 = C.TEXT3}, 0.12)
				end
			end)

			local function buildSubTabBtns()
				for _, child in ipairs(SubRow:GetChildren()) do
					if child:IsA("TextButton") then child:Destroy() end
				end
				for _, stName in ipairs(SUB_TABS) do
					local stData = Tab._subTabs[stName]
					local Btn = Instance.new("TextButton")
					Btn.BackgroundTransparency = 1
					Btn.BorderSizePixel  = 0
					Btn.Size             = UDim2.new(0, 0, 1, 0)
					Btn.AutomaticSize    = Enum.AutomaticSize.X
					Btn.Font             = Enum.Font.GothamBold
					Btn.Text             = stName
					Btn.TextColor3       = C.TEXT2
					Btn.TextSize         = 11
					Btn.ZIndex           = 4
					Btn.Parent           = SubRow
					MakePadding(Btn, 0, 0, 4, 4)

					local Underline = Instance.new("Frame")
					Underline.BackgroundColor3 = C.ACCENT
					Underline.BorderSizePixel  = 0
					Underline.Size             = UDim2.new(1, 0, 0, 2)
					Underline.Position         = UDim2.new(0, 0, 1, -2)
					Underline.Visible          = false
					Underline.ZIndex           = 5
					Underline.Parent           = Btn

					stData.btn      = Btn
					stData.underline = Underline

					local capturedName = stName
					Btn.MouseButton1Click:Connect(function()
						Tab:_selectSubTab(capturedName)
					end)
				end
			end

			function Tab:_selectSubTab(stName)
				local stData = Tab._subTabs[stName]
				if not stData or not stData.btn then return end

				if Tab._activeSTBtn then
					Tween(Tab._activeSTBtn, {TextColor3 = C.TEXT2}, 0.1)
				end
				if Tab._activeST and Tab._subTabs[Tab._activeST] then
					Tab._subTabs[Tab._activeST].underline.Visible = false
					Tab._subTabs[Tab._activeST].frame.Visible     = false
					if Tab._subTabs[Tab._activeST].pad then
						Tab._subTabs[Tab._activeST].pad.PaddingTop = UDim.new(0, 0)
					end
				end

				Tab._activeST    = stName
				Tab._activeSTBtn = stData.btn
				Tween(stData.btn, {TextColor3 = C.TEXT1}, 0.1)
				stData.underline.Visible = true

				if stData.pad then stData.pad.PaddingTop = UDim.new(0, 10) end
				stData.frame.Visible = true
				for _, child in ipairs(stData.frame:GetChildren()) do
					if child:IsA("Frame") or child:IsA("TextButton") then
						child.BackgroundTransparency = 1
						Tween(child, {BackgroundTransparency = 0}, 0.18)
					end
				end
				if stData.pad then
					TweenService:Create(stData.pad,
						TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
						{PaddingTop = UDim.new(0, 0)}):Play()
				end
			end

			SideBtn.MouseButton1Click:Connect(function()
				if Window._activeSideBtn == SideBtn then return end

				local fadingFrames = {}
				for _, t in ipairs(Window._tabs) do
					for _, stName in ipairs(SUB_TABS) do
						local st = t._subTabs[stName]
						if st and st.frame.Visible then
							table.insert(fadingFrames, st.frame)
							for _, child in ipairs(st.frame:GetChildren()) do
								if child:IsA("Frame") or child:IsA("TextButton") then
									Tween(child, {BackgroundTransparency = 1}, 0.12)
								end
							end
						end
					end
				end

				deselectCurrentSideBtn()
				Window._activeSideBtn         = SideBtn
				Window._activeSideBtnNameLbl  = NameLbl
				Window._activeSideBtnIconLbl  = IconLbl
				Window._activeSideBtnAccBar   = AccBar
				Tween(SideBtn, {BackgroundTransparency = 0.75}, 0.15)
				Tween(NameLbl, {TextColor3 = C.TEXT1}, 0.15)
				Tween(IconLbl, {TextColor3 = C.ACCENT_DIM}, 0.15)
				AccBar.Visible = true

				Tween(TopTitle, {TextTransparency = 1}, 0.08)
				Tween(TopDesc,  {TextTransparency = 1}, 0.08)

				task.delay(0.14, function()
					for _, f in ipairs(fadingFrames) do f.Visible = false end
					hideAllTabContent()
					TopTitle.Text = name
					TopDesc.Text  = Tab._desc
					Tween(TopTitle, {TextTransparency = 0}, 0.15)
					Tween(TopDesc,  {TextTransparency = 0}, 0.15)
					buildSubTabBtns()
					Tab._activeST    = nil
					Tab._activeSTBtn = nil
					Tab:_selectSubTab("General")
				end)
			end)

			local function getFrame(subTab)
				local stData = Tab._subTabs[subTab or "General"]
				return stData and stData.frame or nil
			end

