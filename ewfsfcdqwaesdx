					subTab   = t.SubTab
				end

				local frame = getFrame(subTab)
				if not frame then return end

				local selectedSet = {}
				if default then
					for _, v in ipairs(default) do
						selectedSet[v] = true
					end
				end

				local open = false

				local function buildSummary()
					local parts = {}
					for _, opt in ipairs(options) do
						if selectedSet[opt] then
							table.insert(parts, opt)
						end
					end
					if #parts == 0 then return "None" end
					if #parts == #options then return "All" end
					return table.concat(parts, ", ")
				end

				local function getSelected()
					local arr = {}
					for _, opt in ipairs(options) do
						if selectedSet[opt] then
							table.insert(arr, opt)
						end
					end
					return arr
				end

				local Row = Instance.new("Frame")
				Row.BackgroundColor3 = C.ITEM
				Row.BorderSizePixel = 0
				Row.Size = UDim2.new(1, 0, 0, 49)
				Row.ClipsDescendants = false
				Row.ZIndex = 10
				Row.Parent = frame
				MakeCorner(Row, 4)

				local LabelTxt = Instance.new("TextLabel")
				LabelTxt.BackgroundTransparency = 1
				LabelTxt.Size = UDim2.new(1, -16, 0, 20)
				LabelTxt.Position = UDim2.new(0, 16, 0, 6)
				LabelTxt.Font = Enum.Font.GothamBold
				LabelTxt.Text = label
				LabelTxt.TextColor3 = C.TEXT1
				LabelTxt.TextSize = 12
				LabelTxt.TextXAlignment = Enum.TextXAlignment.Left
				LabelTxt.ZIndex = 11
				LabelTxt.Parent = Row

				local MultiBadge = Instance.new("TextLabel")
				MultiBadge.BackgroundColor3 = Color3.fromRGB(25, 25, 38)
				MultiBadge.BackgroundTransparency = 0
				MultiBadge.BorderSizePixel = 0
				MultiBadge.Size = UDim2.new(0, 34, 0, 12)
				MultiBadge.Position = UDim2.new(0, 16 + LabelTxt.TextSize * #label * 0.55 + 6, 0, 10)
				MultiBadge.Font = Enum.Font.GothamBold
				MultiBadge.Text = "MULTI"
				MultiBadge.TextColor3 = C.ACCENT_DIM
				MultiBadge.TextSize = 7
				MultiBadge.ZIndex = 11
				MultiBadge.Parent = Row
				MakeCorner(MultiBadge, 3)

				local DropBtn = Instance.new("TextButton")
				DropBtn.BackgroundColor3 = C.INPUT_BG
				DropBtn.BorderSizePixel = 0
				DropBtn.Size = UDim2.new(1, -32, 0, 22)
				DropBtn.Position = UDim2.new(0, 16, 0, 22)
				DropBtn.Font = Enum.Font.Gotham
				DropBtn.Text = buildSummary()
				DropBtn.TextColor3 = C.TEXT2
				DropBtn.TextSize = 11
				DropBtn.TextXAlignment = Enum.TextXAlignment.Left
				DropBtn.TextTruncate = Enum.TextTruncate.AtEnd
				DropBtn.ZIndex = 11
				DropBtn.Parent = Row
				MakeCorner(DropBtn, 4)
				MakePadding(DropBtn, 0, 0, 8, 28)

				local DropArrow = Instance.new("TextLabel")
				DropArrow.BackgroundTransparency = 1
				DropArrow.Size = UDim2.new(0, 20, 1, 0)
				DropArrow.Position = UDim2.new(1, -22, 0, 0)
				DropArrow.Font = Enum.Font.GothamBold
				DropArrow.Text = "▾"
				DropArrow.TextColor3 = C.TEXT3
				DropArrow.TextSize = 12
				DropArrow.ZIndex = 12
				DropArrow.Parent = DropBtn

				local listH = #options * 28 + 8
				local DropList = Instance.new("Frame")
				DropList.BackgroundColor3 = C.DROPDOWN_BG
				DropList.BorderSizePixel = 0
				DropList.Size = UDim2.new(1, -32, 0, listH)
				DropList.Position = UDim2.new(0, 16, 0, 47)
				DropList.Visible = false
				DropList.ZIndex = 20
				DropList.Parent = Row
				MakeCorner(DropList, 4)
				MakePadding(DropList, 4, 4, 4, 4)
				MakeList(DropList, 2)

				local optBtns = {}

				local function refreshOptColors()
					for _, info in ipairs(optBtns) do
						local isSelected = selectedSet[info.opt]
						Tween(info.check, {
							BackgroundColor3 = isSelected and C.ACCENT or Color3.fromRGB(28,28,38),
							BackgroundTransparency = isSelected and 0 or 0
						}, 0.1)
						info.checkMark.Visible = isSelected
						Tween(info.lbl, {TextColor3 = isSelected and C.TEXT1 or C.TEXT2}, 0.1)
					end
				end

				for _, opt in ipairs(options) do
					local OptRow = Instance.new("TextButton")
					OptRow.BackgroundColor3 = C.DROPDOWN_BG
					OptRow.BackgroundTransparency = 1
					OptRow.BorderSizePixel = 0
					OptRow.Size = UDim2.new(1, 0, 0, 24)
					OptRow.Font = Enum.Font.Gotham
					OptRow.Text = ""
					OptRow.ZIndex = 21
					OptRow.Parent = DropList
					MakeCorner(OptRow, 3)

					local CheckBox = Instance.new("Frame")
					CheckBox.BackgroundColor3 = selectedSet[opt] and C.ACCENT or Color3.fromRGB(28, 28, 38)
					CheckBox.BorderSizePixel = 0
					CheckBox.Size = UDim2.new(0, 14, 0, 14)
					CheckBox.Position = UDim2.new(0, 6, 0.5, -7)
					CheckBox.ZIndex = 22
					CheckBox.Parent = OptRow
					MakeCorner(CheckBox, 3)

					local CheckMark = Instance.new("TextLabel")
					CheckMark.BackgroundTransparency = 1
					CheckMark.Size = UDim2.new(1, 0, 1, 0)
					CheckMark.Font = Enum.Font.GothamBold
					CheckMark.Text = "✓"
					CheckMark.TextColor3 = C.TEXT1
					CheckMark.TextSize = 9
					CheckMark.Visible = selectedSet[opt] or false
					CheckMark.ZIndex = 23
					CheckMark.Parent = CheckBox

					local OptLbl = Instance.new("TextLabel")
					OptLbl.BackgroundTransparency = 1
					OptLbl.Size = UDim2.new(1, -30, 1, 0)
					OptLbl.Position = UDim2.new(0, 26, 0, 0)
					OptLbl.Font = Enum.Font.Gotham
					OptLbl.Text = opt
					OptLbl.TextColor3 = selectedSet[opt] and C.TEXT1 or C.TEXT2
					OptLbl.TextSize = 11
					OptLbl.TextXAlignment = Enum.TextXAlignment.Left
					OptLbl.ZIndex = 22
					OptLbl.Parent = OptRow

					table.insert(optBtns, {opt = opt, check = CheckBox, checkMark = CheckMark, lbl = OptLbl})

					OptRow.MouseEnter:Connect(function()
						Tween(OptRow, {BackgroundTransparency = 0.75}, 0.1)
					end)
					OptRow.MouseLeave:Connect(function()
						Tween(OptRow, {BackgroundTransparency = 1}, 0.1)
					end)
					OptRow.MouseButton1Click:Connect(function()
						selectedSet[opt] = not selectedSet[opt]
						refreshOptColors()
						DropBtn.Text = buildSummary()
						if callback then callback(getSelected()) end
					end)
				end

				DropBtn.MouseButton1Click:Connect(function()
					open = not open
					DropList.Visible = open
					Tween(DropArrow, {Rotation = open and 180 or 0}, 0.15)
				end)

				local ctrl = {}
				function ctrl:Set(arr)
					selectedSet = {}
					for _, v in ipairs(arr) do
						selectedSet[v] = true
					end
					refreshOptColors()
					DropBtn.Text = buildSummary()
					if callback then callback(getSelected()) end
				end
				function ctrl:Get() return getSelected() end
				function ctrl:Toggle(opt)
					selectedSet[opt] = not selectedSet[opt]
					refreshOptColors()
					DropBtn.Text = buildSummary()
					if callback then callback(getSelected()) end
				end
				return ctrl
			end

			------------------------------------------------------------
			-- Tab:AddLabel
			------------------------------------------------------------
			function Tab:AddLabel(text, subTab)
				local frame = getFrame(subTab)
				if not frame then return end

				local Row = Instance.new("Frame")
				Row.BackgroundColor3 = C.ITEM
				Row.BorderSizePixel = 0
				Row.Size = UDim2.new(1, 0, 0, 32)
				Row.ZIndex = 3
				Row.Parent = frame
				MakeCorner(Row, 4)

				local LabelTxt = Instance.new("TextLabel")
				LabelTxt.BackgroundTransparency = 1
				LabelTxt.Size = UDim2.new(1, -16, 1, 0)
				LabelTxt.Position = UDim2.new(0, 16, 0, 0)
				LabelTxt.Font = Enum.Font.Gotham
				LabelTxt.Text = text
				LabelTxt.TextColor3 = C.TEXT2
				LabelTxt.TextSize = 11
				LabelTxt.TextXAlignment = Enum.TextXAlignment.Left
				LabelTxt.ZIndex = 4
				LabelTxt.Parent = Row

				local ctrl = {}
				function ctrl:Set(v) LabelTxt.Text = v end
				function ctrl:Get() return LabelTxt.Text end
				return ctrl
			end

			------------------------------------------------------------
			-- Tab:AddSeparator
			------------------------------------------------------------
			function Tab:AddSeparator(subTab)
				local frame = getFrame(subTab)
				if not frame then return end

				local Sep = Instance.new("Frame")
				Sep.BackgroundColor3 = C.DIVIDER
				Sep.BorderSizePixel = 0
				Sep.Size = UDim2.new(1, 0, 0, 1)
				Sep.ZIndex = 3
				Sep.Parent = frame
			end

			table.insert(Window._tabs, Tab)
			return Tab
		end -- end Category:AddTab

		return Category
	end -- end Window:AddCategory

	return Window
end -- end NeronLib:CreateWindow

return NeronLib
