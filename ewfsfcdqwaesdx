						Tween(OptBtn, {BackgroundTransparency = 0.7}, 0.1)
					end)
					OptBtn.MouseLeave:Connect(function()
						Tween(OptBtn, {BackgroundTransparency = 1}, 0.1)
					end)
					OptBtn.MouseButton1Click:Connect(function()
						selected = opt
						DropBtn.Text = opt
						for _, o in ipairs(DropList:GetChildren()) do
							if o:IsA("TextButton") then
								o.TextColor3 = o.Text == selected and C.TEXT1 or C.TEXT2
							end
						end
						open = false
						DropList.Visible = false
						Tween(DropArrow, {Rotation = 0}, 0.15)
						if callback then callback(selected) end
					end)
				end

				DropBtn.MouseButton1Click:Connect(function()
					open = not open
					DropList.Visible = open
					Tween(DropArrow, {Rotation = open and 180 or 0}, 0.15)
				end)

				local ctrl = {}
				function ctrl:Set(v)
					selected = v
					DropBtn.Text = v
					if callback then callback(selected) end
				end
				function ctrl:Get() return selected end
				return ctrl
			end

